    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description"
        content="Servicios tecnológicos integrales INCUYO - Transformación digital para empresas medianas. Soluciones a medida, procesos claros y soporte continuo." />
    <meta name="keywords"
        content="servicios tecnológicos, transformación digital, desarrollo software, Mendoza, INCUYO" />
    <title>Servicios Tecnológicos - INCUYO</title>

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="./public/img/favicon.ico" />

    <!-- Stylesheet -->
    <link rel="stylesheet" href="/css/style.css" />

    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>

<body>
    <!-- NAVIGATION -->
    <nav class="navbar" id="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <img src="/assets/img/logo.png" alt="Instituto Nuevo Cuyo" class="navbar-logo" />
            </a>

            <button class="navbar-toggle" id="navbarToggle" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <ul class="navbar-menu" id="navbarMenu">
                <li><a href="/">Inicio</a></li>
                <li><a href="/#inscripciones">Inscripciones</a></li>
                <li><a href="/proyectosalumnos">Proyectos</a></li>
                <li>
                    <a href="https://aula.incuyo.edu.ar/" target="_blank" class="campus-link">Campus Virtual</a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="hero" id="inicio">
        <!-- YouTube Background Video -->
        <div class="hero-youtube-bg">
            <iframe src="https://www.youtube.com/embed/CAR51VbQ4Xg?si=6LTIF48Auz3EWjk-&autoplay=1&mute=1&loop=1&playlist=CAR51VbQ4Xg&controls=0&showinfo=0&rel=0&playsinline=1" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        </div>
        <!-- Glassmorphism Overlay -->
        <div class="hero-glass-overlay"></div>
        <div class="container" style="position: relative; z-index: 2;">
            <div class="hero-content">
                <h1 class="hero-title">Servicios tecnológicos integrales</h1>
                <p class="hero-description">
                    Acompañamos a empresas medianas en su transformación digital con
                    soluciones a medida, procesos claros y soporte continuo post-implementación.
                </p>
                <div class="hero-cta-group" style="justify-content: center;">
                    <a href="#servicios" class="btn btn-gold btn-lg hero-cta-btn">
                        <i class="fas fa-arrow-down"></i> Ver servicios
                    </a>
                    <a href="#contacto" class="btn btn-outline-white btn-lg">
                        <i class="fas fa-envelope"></i> Contactar
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- DESCRIPCIÓN / INTRO -->
    <section class="section program-info" id="nosotros">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Nuestra Propuesta</p>
                <h2 class="section-title">Transformación digital para su empresa</h2>
                <p class="section-description">
                    Nos especializamos en acompañar a empresas medianas en su transformación digital,
                    ofreciendo soluciones a medida, con procesos claros, entregas en tiempo y soporte
                    continuo post-implementación.
                </p>
            </div>

            <!-- Pillars -->
            <div class="grid grid-cols-3 feature-grid reveal" style="margin-top: 4rem;">
                <div class="card">
                    <div class="card-icon">
                        <i class="fas fa-drafting-compass icon"></i>
                    </div>
                    <h3 class="card-title">Soluciones a medida</h3>
                    <p class="card-text">
                        Cada proyecto se diseña según las necesidades reales de su empresa,
                        sin soluciones genéricas.
                    </p>
                </div>

                <div class="card">
                    <div class="card-icon">
                        <i class="fas fa-clipboard-list icon"></i>
                    </div>
                    <h3 class="card-title">Procesos claros</h3>
                    <p class="card-text">
                        Metodología transparente con etapas, entregables y plazos definidos
                        desde el inicio.
                    </p>
                </div>

                <div class="card">
                    <div class="card-icon">
                        <i class="fas fa-life-ring icon"></i>
                    </div>
                    <h3 class="card-title">Soporte continuo</h3>
                    <p class="card-text">
                        Acompañamiento real después de la entrega, sin costos ocultos ni
                        tiempos de respuesta indefinidos.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- SERVICIOS SECTION -->
    <section class="section section-dark" id="servicios">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle" style="color: var(--primary-gold)">Lo que ofrecemos</p>
                <h2 class="section-title">Nuestros Servicios</h2>
                <p class="section-description">
                    Un portfolio completo de soluciones tecnológicas para potenciar cada
                    área de su empresa.
                </p>
            </div>

            <div class="grid grid-cols-3 feature-grid reveal">
                <div class="card card-glass">
                    <div class="card-icon">
                        <i class="fas fa-sitemap icon"></i>
                    </div>
                    <h3 class="card-title">Digitalización de Procesos</h3>
                    <p class="card-text">
                        Relevamiento, modelado y automatización de los flujos internos,
                        eliminando papel y tareas manuales repetitivas.
                    </p>
                </div>

                <div class="card card-glass">
                    <div class="card-icon">
                        <i class="fas fa-store icon"></i>
                    </div>
                    <h3 class="card-title">Canales de Venta Digitales</h3>
                    <p class="card-text">
                        Desarrollo de e-commerce, catálogos online y plataformas B2B que
                        amplían su alcance comercial.
                    </p>
                </div>

                <div class="card card-glass">
                    <div class="card-icon">
                        <i class="fas fa-headset icon"></i>
                    </div>
                    <h3 class="card-title">Atención al Cliente Digital</h3>
                    <p class="card-text">
                        Portales de autogestión y sistemas de soporte para mejorar la
                        experiencia de sus clientes.
                    </p>
                </div>

                <div class="card card-glass">
                    <div class="card-icon">
                        <i class="fas fa-database icon"></i>
                    </div>
                    <h3 class="card-title">Gestión de Datos e Informes</h3>
                    <p class="card-text">
                        Dashboards en tiempo real e informes ejecutivos para decisiones
                        basadas en datos confiables.
                    </p>
                </div>

                <div class="card card-glass">
                    <div class="card-icon">
                        <i class="fas fa-shield-alt icon"></i>
                    </div>
                    <h3 class="card-title">Seguridad y Cumplimiento</h3>
                    <p class="card-text">
                        Auditorías de seguridad y políticas de privacidad alineadas a
                        normativas vigentes.
                    </p>
                </div>

                <div class="card card-glass">
                    <div class="card-icon">
                        <i class="fas fa-tools icon"></i>
                    </div>
                    <h3 class="card-title">Soporte y Mantenimiento</h3>
                    <p class="card-text">
                        Soporte técnico continuo post-implementación y monitoreo para
                        garantizar la disponibilidad de sus sistemas.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- DIFERENCIAL -->
    <section class="section certifications" id="diferencial">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Por qué elegirnos</p>
                <h2 class="section-title">Nuestro diferencial</h2>
                <p class="section-description">
                    Precios transparentes y un esquema de trabajo profesional que garantiza
                    resultados reales.
                </p>
            </div>

            <div class="cert-year-grid">
                <div class="cert-year-card reveal">
                    <h3 class="cert-year"><i class="fas fa-drafting-compass"></i></h3>
                    <ul class="cert-list">
                        <li>A medida para su negocio</li>
                        <li>Sin soluciones genéricas</li>
                    </ul>
                </div>

                <div class="cert-year-card reveal">
                    <h3 class="cert-year"><i class="fas fa-calendar-check"></i></h3>
                    <ul class="cert-list">
                        <li>Entregas en tiempo</li>
                        <li>Plazos comprometidos</li>
                    </ul>
                </div>

                <div class="cert-year-card reveal">
                    <h3 class="cert-year"><i class="fas fa-hand-holding-usd"></i></h3>
                    <ul class="cert-list">
                        <li>Precios transparentes</li>
                        <li>Sin costos ocultos</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA / CONTACTO -->
    <section class="section section-dark enrollment" id="contacto">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle" style="color: var(--primary-gold)">Hablemos de su proyecto</p>
                <h2 class="section-title">Iniciemos la transformación digital</h2>
            </div>

            <div class="highlight-box reveal">
                <div class="text-center">
                    <div class="scholarship-badge">
                        <i class="fas fa-microchip"></i> SERVICIOS TECNOLÓGICOS INTEGRALES
                    </div>
                    <p style="color: white; font-size: 1.125rem; margin-bottom: 2rem">
                        Contáctenos y diseñamos juntos el plan de digitalización para su empresa.
                    </p>
                </div>

                <div class="highlight-grid">
                    <div class="highlight-item reveal">
                        <div class="highlight-item-icon"><i class="fas fa-sitemap"></i></div>
                        <p class="highlight-item-text">Digitalice sus procesos internos</p>
                    </div>
                    <div class="highlight-item reveal">
                        <div class="highlight-item-icon"><i class="fas fa-store"></i></div>
                        <p class="highlight-item-text">Amplíe sus canales de venta</p>
                    </div>
                    <div class="highlight-item reveal">
                        <div class="highlight-item-icon"><i class="fas fa-headset"></i></div>
                        <p class="highlight-item-text">Optimice la atención al cliente</p>
                    </div>
                </div>

                <div class="text-center" style="margin-top: 2rem">
                    <a href="mailto:majrodriguez@mendoza.edu.ar" class="btn btn-primary btn-lg">
                        <i class="fas fa-envelope"></i> Contactar por correo
                    </a>
                </div>
            </div>
        </div>
    </section>

