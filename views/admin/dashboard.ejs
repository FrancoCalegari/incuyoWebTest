        // ─── SpiderIA Status ──────────────────────────
        let _selectedModelId = null; // modelo seleccionado en la UI (null = auto)

        async function loadSpiderStatus() {
            const box = document.getElementById('spiderStatusBox');
            const icon = document.getElementById('spiderRefreshIcon');
            const selectorSection = document.getElementById('modelSelectorSection');
            icon.classList.add('fa-spin');
            box.innerHTML = '<div style="text-align:center;padding:2rem;color:#aaa;"><i class="fas fa-spinner fa-spin" style="font-size:2rem;"></i><p style="margin-top:0.75rem;">Consultando SpiderIA...</p></div>';
            selectorSection.style.display = 'none';

            try {
                // Cargar estado de SpiderIA y modelo activo en paralelo
                const [data, selectedData] = await Promise.all([
                    apiCall('/admin/api/spideria-status'),
                    apiCall('/admin/api/spideria-selected-model'),
                ]);
                _selectedModelId = selectedData.model_id ?? null;

                if (!data.ok) {
                    box.innerHTML = `
                        <div class="spider-status-error">
                            <i class="fas fa-exclamation-triangle"></i>
                            <div>
                                <strong>SpiderIA no disponible</strong>
                                <p>${data.error || 'No se pudo conectar al servidor de IA.'}</p>
                                <p style="font-size:0.8rem;color:#aaa;margin-top:0.4rem;">URL consultada: <code>${data.url || '?'}</code></p>
                            </div>
                        </div>`;
                    icon.classList.remove('fa-spin');
                    return;
                }

                const models = data.models || [];
                const usage = data.usage || null;

                let usageHtml = '';
                if (usage) {
                    const history = usage.history || [];
                    const callsToday = usage.calls_today ?? '?';
                    const quotaDaily = usage.quota_daily ?? null;
                    const pct = (quotaDaily && quotaDaily !== null) ? Math.round((callsToday / quotaDaily) * 100) : null;

                    // Calcular tokens del día actual
                    const today = new Date().toISOString().split('T')[0];
                    const todayRows = history.filter(h => h.usage_date && h.usage_date.startsWith(today));
                    const tokensToday = todayRows.reduce((acc, h) => acc + (h.tokens_approx || 0), 0);

                    let historyHtml = history.length === 0 ? '<p style="color:#aaa;font-size:0.82rem;">Sin historial disponible.</p>' :
                        `<table style="width:100%;border-collapse:collapse;font-size:0.8rem;margin-top:0.5rem;">
                            <thead><tr style="color:black;text-align:left;">
                                <th style="padding:0.3rem 0.5rem;">Fecha</th>
                                <th style="padding:0.3rem 0.5rem;">Modelo</th>
                                <th style="padding:0.3rem 0.5rem;">Llamadas</th>
                                <th style="padding:0.3rem 0.5rem;">Tokens ~</th>
                            </tr></thead>
                            <tbody>${history.map(h => `
                                <tr style="border-top:1px solid #f1f5f9; color:black">
                                    <td style="padding:0.3rem 0.5rem;color:#64748b;">${h.usage_date ? h.usage_date.split('T')[0] : '?'}</td>
                                    <td style="padding:0.3rem 0.5rem;font-weight:600;">${h.model || '?'}</td>
                                    <td style="padding:0.3rem 0.5rem;">${h.call_count}</td>
                                    <td style="padding:0.3rem 0.5rem;">${(h.tokens_approx || 0).toLocaleString()}</td>
                                </tr>`).join('')}
                            </tbody>
                        </table>`;

                    usageHtml = `
                        <div class="spider-usage-card">
                            <div class="spider-usage-title"><i class="fas fa-chart-bar"></i> Uso de cuota</div>
                            <div style="display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:0.75rem;">
                                <div><div style="font-size:1.4rem;font-weight:800;color:#1e293b;">${callsToday}</div><div style="font-size:0.76rem;color:#94a3b8;">llamadas hoy</div></div>
                                <div><div style="font-size:1.4rem;font-weight:800;color:#1e293b;">${tokensToday.toLocaleString()}</div><div style="font-size:0.76rem;color:#94a3b8;">tokens hoy ~</div></div>
                                <div><div style="font-size:1.4rem;font-weight:800;color:#1e293b;">${quotaDaily ?? '∞'}</div><div style="font-size:0.76rem;color:#94a3b8;">límite diario</div></div>
                            </div>
                            ${pct !== null ? `
                            <div class="spider-usage-bar-wrap"><div class="spider-usage-bar" style="width:${pct}%"></div></div>
                            <div class="spider-usage-nums"><span>${callsToday} usados</span><span>${pct}%</span><span>Límite: ${quotaDaily}</span></div>` : ''}
                            <details style="margin-top:0.75rem;">
                                <summary style="font-size:0.8rem;color:#94a3b8;cursor:pointer;">Ver historial detallado</summary>
                                ${historyHtml}
                            </details>
                        </div>`;
                }

                box.innerHTML = `
                    <div class="spider-online-badge"><i class="fas fa-check-circle"></i> SpiderIA en línea — ${models.length} modelo${models.length !== 1 ? 's' : ''} disponible${models.length !== 1 ? 's' : ''}</div>
                    <p style="font-size:0.8rem;color:#aaa;margin-bottom:1rem;">URL: <code>${data.url || '?'}</code></p>
                    ${usageHtml}`;

                // Renderizar el selector de modelo
                renderModelSelector(models, _selectedModelId);
                selectorSection.style.display = '';

            } catch (err) {
                box.innerHTML = `<div class="spider-status-error"><i class="fas fa-exclamation-triangle"></i><div><strong>Error</strong><p>${err.message}</p></div></div>`;
            }

            icon.classList.remove('fa-spin');
        }

        function renderModelSelector(models, activeModelId) {
            const grid = document.getElementById('modelSelectorGrid');
            const isAuto = activeModelId === null;
            grid.innerHTML = models.map(m => {
                const isActive = m.id == activeModelId;
                return `
                    <div class="spider-model-card ${isActive ? 'spider-model-card--active' : ''}" onclick="selectModel(${m.id})" style="cursor:pointer;" data-model-id="${m.id}">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                            <div class="spider-model-status"><i class="fas fa-circle"></i> Disponible</div>
                            ${isActive ? '<span class="spider-active-badge"><i class="fas fa-check"></i> ACTIVO</span>' : ''}
                        </div>
                        <div class="spider-model-name">${m.name || m.model || m.id || JSON.stringify(m)}</div>
                        <div class="spider-model-meta">
                            <span><i class="fas fa-hashtag"></i> ID: <code>${m.id ?? '—'}</code></span>
                            ${m.type ? `<span><i class="fas fa-tag"></i> ${m.type}</span>` : ''}
                            ${m.context_length ? `<span><i class="fas fa-text-width"></i> Ctx: ${m.context_length.toLocaleString()}</span>` : ''}
                        </div>
                    </div>`;
            }).join('');
        }

        function selectModel(modelId) {
            _selectedModelId = modelId;
            document.querySelectorAll('#modelSelectorGrid .spider-model-card').forEach(card => {
                const id = parseInt(card.dataset.modelId, 10);
                const isActive = id === modelId;
                card.classList.toggle('spider-model-card--active', isActive);
                // Actualizar badge
                const existingBadge = card.querySelector('.spider-active-badge');
                if (isActive && !existingBadge) {
                    card.querySelector('.spider-model-status').insertAdjacentHTML('afterend', '<span class="spider-active-badge"><i class="fas fa-check"></i> ACTIVO</span>');
                } else if (!isActive && existingBadge) {
                    existingBadge.remove();
                }
            });
        }

        function selectModelAuto() {
            _selectedModelId = null;
            document.querySelectorAll('#modelSelectorGrid .spider-model-card').forEach(card => {
                card.classList.remove('spider-model-card--active');
                card.querySelector('.spider-active-badge')?.remove();
            });
        }

        async function saveModelSelection() {
            const btn = document.getElementById('saveModelBtn');
            const badge = document.getElementById('modelSavedBadge');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
            try {
                await apiCall('/admin/api/spideria-selected-model', 'POST', { model_id: _selectedModelId });
                badge.style.display = 'inline-flex';
                showToast(_selectedModelId !== null
                    ? `✅ Modelo ID ${_selectedModelId} seleccionado y guardado`
                    : '✅ Modo auto activado (usar primer modelo disponible)');
                setTimeout(() => badge.style.display = 'none', 4000);
            } catch (err) {
                showToast('Error al guardar modelo: ' + err.message, 'error');
            }
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save"></i> Guardar selección';
        }

        // Auto-cargar cuando se abre el panel IA
        document.querySelectorAll('.sidebar-nav a').forEach(link => {
            link.addEventListener('click', () => {
                if (link.dataset.panel === 'ia') loadSpiderStatus();
            });
        });


        // ─── SpiderIA Test ──────────────────────────
        async function runSpiderTest() {
            const prompt = document.getElementById('spiderTestPrompt').value.trim();
            const resultBox = document.getElementById('spiderTestResult');
            const btn = document.getElementById('spiderTestBtn');
            if (!prompt) return;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
            resultBox.innerHTML = '<div style="color:#aaa;font-size:0.88rem;"><i class="fas fa-spinner fa-spin"></i> Esperando respuesta de SpiderIA…</div>';

            try {
                const data = await apiCall('/admin/api/spideria-test', 'POST', { prompt });

                const badge = data.ok
                    ? `<span class="st-badge st-ok"><i class="fas fa-check-circle"></i> Éxito</span>`
                    : `<span class="st-badge st-err"><i class="fas fa-times-circle"></i> Error</span>`;

                const metaItems = [
                    data.url       ? `<span><i class="fas fa-link"></i> ${data.url}</span>` : '',
                    data.modelId   ? `<span><i class="fas fa-cube"></i> Modelo ID: <code>${data.modelId}</code></span>` : '',
                    data.httpStatus ? `<span><i class="fas fa-server"></i> HTTP ${data.httpStatus}</span>` : '',
                    data.elapsed_ms !== null ? `<span><i class="fas fa-clock"></i> ${data.elapsed_ms} ms</span>` : '',
                ].filter(Boolean).join('');

                let body = '';
                if (data.ok) {
                    body = `<div class="st-response-box">${data.response.replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>')}</div>`;
                } else {
                    body = `<div class="st-error-box"><i class="fas fa-exclamation-triangle"></i> ${data.error || 'Error desconocido'}</div>`;
                }

                const rawToggleId = 'stRaw_' + Date.now();
                const rawSection = data.rawJson
                    ? `<details style="margin-top:0.75rem;">
                        <summary style="font-size:0.8rem;color:#94a3b8;cursor:pointer;">Ver JSON crudo</summary>
                        <pre class="st-raw">${JSON.stringify(data.rawJson, null, 2).replace(/</g,'&lt;')}</pre>
                       </details>`
                    : '';

                resultBox.innerHTML = `
                    <div class="st-result">
                        <div class="st-result-header">${badge}<div class="st-meta">${metaItems}</div></div>
                        ${body}
                        ${rawSection}
                    </div>`;

            } catch (err) {
                resultBox.innerHTML = `<div class="st-error-box"><i class="fas fa-exclamation-triangle"></i> Error de red: ${err.message}</div>`;
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-paper-plane"></i> Probar';
        }

        // ─── BECAS LOGIC ─────────────────────────────────────
        function viewBeca(btn) {
            const tr = btn.closest('tr');
            const data = JSON.parse(decodeURIComponent(tr.dataset.beca));
            
            document.getElementById('becaName').textContent = data.first_name + ' ' + data.last_name;
            document.getElementById('becaEmail').textContent = data.email;
            document.getElementById('becaPhone').textContent = data.phone || '–';
            document.getElementById('becaReason').textContent = data.reason || 'Sin motivo especificado';
            
            let dt = new Date(data.created_at);
            document.getElementById('becaDate').textContent = dt.toLocaleDateString('es-AR') + ' ' + dt.toLocaleTimeString('es-AR');

            // Email link
            const emailBtn = document.getElementById('becaBtnEmail');
            emailBtn.href = `mailto:${data.email}?subject=Respuesta%20a%20tu%20solicitud%20de%20Beca%20-%20Instituto%20INCUYO`;

            // WhatsApp link
            const waBtn = document.getElementById('becaBtnWhatsApp');
            if (data.phone) {
                // Remove non numeric chars except +
                let num = data.phone.replace(/[^\d+]/g, '');
                if (!num.startsWith('+')) {
                    // Assuming Argentina (+549) if not specified, simple normalization
                    if (num.startsWith('0')) num = num.substring(1);
                    if (num.startsWith('15')) num = num.substring(2);
                    if (!num.startsWith('54')) num = '549' + num;
                }
                waBtn.href = `https://wa.me/${num}?text=Hola%20${encodeURIComponent(data.first_name)},%20te%20contactamos%20desde%20el%20Instituto%20INCUYO...`;
                waBtn.style.display = 'block';
            } else {
                waBtn.style.display = 'none';
            }

            document.getElementById('becaModal').classList.add('active');
        }

        function closeBecaModal() {
            document.getElementById('becaModal').classList.remove('active');
        }

        async function deleteBeca(id) {
            if (!confirm('¿Seguro que querés eliminar esta solicitud?')) return;
            try {
                const res = await fetch(`/admin/api/scholarships/${id}`, { method: 'DELETE' });
                if (res.ok) window.location.reload();
                else alert('Error al eliminar');
            } catch (err) {
                alert('Error de conexión');
            }
        }
    </script>

