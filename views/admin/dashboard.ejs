            <!-- ═══ IA PANEL ═══ -->
            <div class="panel" id="panel-ia">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-robot"></i> Estado de SpiderIA</h3>
                        <button class="btn btn-gold" onclick="loadSpiderStatus()">
                            <i class="fas fa-sync-alt" id="spiderRefreshIcon"></i> Actualizar
                        </button>
                    </div>

                    <div id="spiderStatusBox">
                        <div style="text-align:center; padding:3rem; color:#aaa;">
                            <i class="fas fa-robot" style="font-size:3rem; display:block; margin-bottom:1rem; opacity:0.3;"></i>
                            <p>Hacé clic en <strong>Actualizar</strong> para consultar el estado de la IA.</p>
                        </div>
                    </div>

                    <!-- Selector de modelo activo -->
                    <div class="spider-model-selector-section" id="modelSelectorSection" style="display:none;">
                        <h4><i class="fas fa-sliders-h"></i> Modelo activo del chatbot</h4>
                        <p style="color:#888; font-size:0.88rem; margin-bottom:1rem;">
                            El modelo seleccionado se usará para todas las consultas del chatbot. La selección se persiste en la base de datos.
                        </p>
                        <div id="modelSelectorGrid"></div>
                        <div style="margin-top:1rem; display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
                            <button class="btn btn-gold" onclick="saveModelSelection()" id="saveModelBtn">
                                <i class="fas fa-save"></i> Guardar selección
                            </button>
                            <button class="btn btn-secondary" onclick="selectModelAuto()">
                                <i class="fas fa-magic"></i> Auto (primer modelo)
                            </button>
                            <span id="modelSavedBadge" style="display:none; font-size:0.82rem; color:#059669; font-weight:600;">
                                <i class="fas fa-check-circle"></i> Guardado
                            </span>
                        </div>
                    </div>

                    <!-- Prueba de chat -->
                    <div class="spider-test-section">
                        <h4><i class="fas fa-vial"></i> Prueba de chat</h4>
                        <p style="color:#888; font-size:0.88rem; margin-bottom:1rem;">Envía un mensaje directo a SpiderIA y verás la respuesta o el error exacto que devuelve el servidor.</p>
                        <div style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:flex-start;">
                            <textarea id="spiderTestPrompt" rows="2"
                                placeholder="Ej: Hola, ¿cómo estás?"
                                style="flex:1; min-width:220px; font-family:inherit; font-size:0.9rem; border:1px solid #ddd; border-radius:8px; padding:0.6rem 0.8rem; resize:vertical;">Hola, ¿cómo estás?</textarea>
                            <button class="btn btn-gold" onclick="runSpiderTest()" id="spiderTestBtn">
                                <i class="fas fa-paper-plane"></i> Probar
                            </button>
                        </div>
                        <div id="spiderTestResult" style="margin-top:1.25rem;"></div>
                    </div>
                </div>
            </div>

            <!-- ═══ BECAS PANEL ═══ -->
            <div class="panel" id="panel-becas">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-envelope-open-text"></i> Solicitudes de Becas</h3>
                    </div>

                    <% if (typeof scholarships !== 'undefined' && scholarships.length > 0) { %>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Nombre Completo</th>
                                    <th>Email</th>
                                    <th>Teléfono</th>
                                    <th style="text-align:right">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% scholarships.forEach(function(b) { 
                                    let dt = new Date(b.created_at);
                                    let dateStr = dt.toLocaleDateString('es-AR') + ' ' + dt.toLocaleTimeString('es-AR', {hour: '2-digit', minute:'2-digit'});
                                %>
                                    <tr data-id="<%= b.id %>" data-beca="<%- encodeURIComponent(JSON.stringify(b)) %>">
                                        <td><span style="font-size:0.85rem; color:#666;"><%= dateStr %></span></td>
                                        <td><strong><%= b.first_name %> <%= b.last_name %></strong></td>
                                        <td><%= b.email %></td>
                                        <td><%= b.phone || '–' %></td>
                                        <td style="text-align:right">
                                            <button class="btn btn-secondary btn-sm" onclick="viewBeca(this)">
                                                <i class="fas fa-eye"></i> Ver
                                            </button>
                                            <button class="btn btn-danger btn-sm" onclick="deleteBeca(<%= b.id %>)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div style="text-align:center; padding: 3rem; color: #999;">
                            <i class="fas fa-envelope-open" style="font-size:3rem; opacity:0.3; display:block; margin-bottom:1rem;"></i>
                            <p>No hay solicitudes de becas recibidas aún.</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- ═══ LIVE CHAT PANEL ═══ -->
            <div class="panel" id="panel-livechat">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-comments"></i> Chat en Vivo</h3>
                        <div style="display:flex;gap:0.5rem;align-items:center;">
                            <!-- <button class="btn btn-secondary btn-sm" id="lcInitTablesBtn" onclick="lcInitTables()" title="Inicializar tablas en la DB si es la primera vez">
                                <i class="fas fa-database"></i> Inicializar BD
                            </button> -->
                            <button class="btn btn-gold" onclick="lcLoadSessions()">
                                <i class="fas fa-sync-alt" id="lcRefreshIcon"></i> Actualizar
                            </button>
                        </div>
                    </div>
                    <p style="color:#888;font-size:0.88rem;margin-bottom:1.5rem;">
                        Las sesiones con borde naranja son solicitudes pendientes de asistencia. El panel se actualiza automáticamente cada 10 segundos.
                    </p>

                    <div id="lcSessionsList">
                        <div style="text-align:center;padding:3rem;color:#aaa;">
                            <i class="fas fa-comments" style="font-size:3rem;display:block;margin-bottom:1rem;opacity:0.3;"></i>
                            <p>Hacé clic en <strong>Actualizar</strong> para cargar las sesiones activas.</p>
                        </div>
                    </div>
                </div>

                <!-- ─── Chat Detail Panel ─── -->
                <div id="lcChatDetail" style="display:none;">
                    <div class="panel-section" style="border-top:2px solid var(--border-color,#e5e7eb);margin-top:1.5rem;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                            <h4 style="margin:0;"><i class="fas fa-comment-dots"></i> Conversación <span id="lcDetailSessionId" style="font-size:0.8rem;color:#aaa;font-weight:400;"></span></h4>
                            <div style="display:flex;gap:0.5rem;">
                                <button class="btn btn-gold btn-sm" id="lcTakeControlBtn" onclick="lcTakeControl()">
                                    <i class="fas fa-hand-paper"></i> Tomar control
                                </button>
                                <button class="btn btn-danger btn-sm" onclick="lcCloseSession()">
                                    <i class="fas fa-times-circle"></i> Cerrar sesión
                                </button>
                                <button class="btn btn-secondary btn-sm" style="background-color: #dc3545; color: white; border: none;" onclick="lcDeleteSession()" title="Borrar chat permanentemente">
                                    <i class="fas fa-trash-alt"></i> Borrar
                                </button>
                                <button class="btn btn-secondary btn-sm" onclick="lcHideDetail()">
                                    <i class="fas fa-chevron-up"></i> Ocultar
                                </button>
                            </div>
                        </div>

                        <!-- Messages area -->
                        <div class="lc-messages-area" id="lcMessagesArea"></div>

                        <!-- Admin input -->
                        <div class="lc-admin-input-area" id="lcAdminInputArea">
                            <textarea id="lcAdminInput" rows="2" placeholder="Escribí tu respuesta al visitante..." style="flex:1;font-family:inherit;font-size:0.9rem;border:1px solid #ddd;border-radius:8px;padding:0.6rem 0.8rem;resize:vertical;"></textarea>
                            <button class="btn btn-gold" onclick="lcSendAdminMessage()" id="lcAdminSendBtn">
                                <i class="fas fa-paper-plane"></i> Enviar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </main>
