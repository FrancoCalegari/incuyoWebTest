<!doctype html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - Instituto INCUYO Admin</title>
    <link rel="icon" type="image/png"
        href="https://aula.incuyo.edu.ar/pluginfile.php/1/theme_academi/logo/1756927387/logo%203.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="./css/admin.css">
</head>

<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <button class="mobile-toggle" id="mobileToggle"><i class="fas fa-bars"></i></button>

    <div class="dashboard">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <img src="/assets/img/logo.png" alt="INCUYO">
                <span>INCUYO Admin</span>
            </div>

            <ul class="sidebar-nav">
                <li><a href="#" class="active" data-panel="curriculum"><i class="fas fa-book"></i> Plan de Estudios</a></li>
                <li><a href="#" data-panel="commitment"><i class="fas fa-heart"></i> Compromiso Social</a></li>
                <li><a href="#" data-panel="projects"><i class="fas fa-code"></i> Proyectos Alumnos</a></li>
                <li><a href="#" data-panel="testimonios"><i class="fas fa-video"></i> Testimonios</a></li>
                <li><a href="#" data-panel="diplomaturas"><i class="fas fa-graduation-cap"></i> Diplomaturas</a></li>
                <li><a href="#" data-panel="pasantias"><i class="fas fa-building"></i> Pasantías</a></li>
                <li><a href="#" data-panel="configuracion"><i class="fas fa-cog"></i> Configuración</a></li>
                <li><a href="#" data-panel="textos"><i class="fas fa-font"></i> Textos Fijos</a></li>
                <li><a href="#" data-panel="ia"><i class="fas fa-robot"></i> Estado IA</a></li>
                <li><a href="#" data-panel="becas"><i class="fas fa-envelope-open-text"></i> Becas</a></li>
                <li><a href="#" data-panel="livechat" id="livechatSidebarLink"><i class="fas fa-comments"></i> Chat en Vivo <span class="livechat-badge" id="livechatBadge" style="display:none;"></span></a></li>
            </ul>

            <div class="sidebar-bottom">
                <a href="/"><i class="fas fa-globe"></i> Ver Sitio Web</a>
                <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Cerrar Sesión</a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="page-header">
                <h1>Panel de Administración</h1>
                <p>Gestioná el contenido del sitio web del Instituto INCUYO</p>
            </div>

            <!-- ═══ CURRICULUM PANEL ═══ -->
            <div class="panel active" id="panel-curriculum">
                <!-- Sub-tabs -->
                <div class="curr-sub-tabs" style="display:flex; gap:0; margin-bottom:1.5rem; border-bottom:2px solid var(--border-color, #e5e7eb);">
                    <button class="curr-sub-tab active" data-subtab="materias" onclick="switchCurrTab('materias', this)" style="padding:0.7rem 1.5rem; background:none; border:none; border-bottom:3px solid transparent; font-weight:600; cursor:pointer; color:#888; transition:all 0.2s;">
                        <i class="fas fa-book"></i> Materias
                    </button>
                    <button class="curr-sub-tab" data-subtab="certificaciones" onclick="switchCurrTab('certificaciones', this)" style="padding:0.7rem 1.5rem; background:none; border:none; border-bottom:3px solid transparent; font-weight:600; cursor:pointer; color:#888; transition:all 0.2s;">
                        <i class="fas fa-award"></i> Certificaciones Laborales
                    </button>
                </div>

                <!-- Sub-panel: Materias -->
                <div class="curr-subpanel" id="subpanel-materias">
                    <div class="panel-section">
                        <div class="panel-title">
                            <h3><i class="fas fa-book"></i> Plan de Estudios</h3>
                            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                <button class="btn btn-danger" onclick="clearCurriculum()">
                                    <i class="fas fa-trash-alt"></i> Limpiar Todo
                                </button>
                                <button class="btn btn-gold" onclick="openCurriculumModal()">
                                    <i class="fas fa-plus"></i> Agregar Materia
                                </button>
                            </div>
                        </div>

                        <div class="filter-tabs">
                            <button class="filter-tab active" data-filter="all" onclick="filterCurriculum('all', this)">Todos</button>
                            <button class="filter-tab" data-filter="1" onclick="filterCurriculum(1, this)">1° Año</button>
                            <button class="filter-tab" data-filter="2" onclick="filterCurriculum(2, this)">2° Año</button>
                            <button class="filter-tab" data-filter="3" onclick="filterCurriculum(3, this)">3° Año</button>
                        </div>

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Año</th>
                                    <th>Materia</th>
                                    <th>Semestre</th>
                                    <th>Orden</th>
                                    <th style="text-align:right">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="curriculumTable">
                                <% curriculum.forEach(function(item) { %>
                                    <tr data-id="<%= item.id %>" data-year="<%= item.year %>"
                                        data-name="<%- encodeURIComponent(item.subject_name) %>"
                                        data-order="<%= item.order_index %>"
                                        data-semestre="<%= item.semestre || '' %>">
                                        <td><span class="year-badge y<%= item.year %>"><%= item.year %>° Año</span></td>
                                        <td><%= item.subject_name %></td>
                                        <td><% if (item.semestre) { %><span style="font-size:0.8rem; background:#f0f4ff; color:#4f6ef7; padding:2px 8px; border-radius:99px;"><%= item.semestre === 'anual' ? 'Anual' : item.semestre + '° Semestre' %></span><% } else { %><span style="color:#ccc; font-size:0.8rem;">—</span><% } %></td>
                                        <td><%= item.order_index %></td>
                                        <td style="text-align:right">
                                            <button class="btn btn-secondary btn-sm" onclick="editCurrFromRow(this)">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-danger btn-sm" onclick="deleteCurriculum(<%= item.id %>)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Sub-panel: Certificaciones Laborales -->
                <div class="curr-subpanel" id="subpanel-certificaciones" style="display:none;">
                    <div class="panel-section">
                        <div class="panel-title">
                            <h3><i class="fas fa-award"></i> Certificaciones Laborales</h3>
                            <button class="btn btn-gold" onclick="openCertModal()">
                                <i class="fas fa-plus"></i> Agregar Certificación
                            </button>
                        </div>
                        <p style="color:#888; font-size:0.88rem; margin-bottom:1.5rem;">Máximo 10 certificaciones por año. Se obtienen al aprobar coprogramáticas.</p>

                        <% [1,2,3].forEach(function(yr) {
                            const certs = certificaciones.filter(c => c.year == yr);
                        %>
                        <div style="margin-bottom:2rem;">
                            <h4 style="margin-bottom:0.75rem; display:flex; align-items:center; gap:0.5rem;">
                                <span class="year-badge y<%= yr %>"><%= yr %>° Año</span>
                                <span style="font-size:0.82rem; color:#aaa;">(<%= certs.length %>/10)</span>
                            </h4>
                            <% if (certs.length === 0) { %>
                                <p style="color:#bbb; font-size:0.9rem; padding-left:0.5rem;">Sin certificaciones cargadas.</p>
                            <% } else { %>
                            <table class="data-table">
                                <thead><tr><th>Nombre</th><th>Orden</th><th style="text-align:right">Acciones</th></tr></thead>
                                <tbody>
                                <% certs.forEach(function(cert) { %>
                                    <tr data-id="<%= cert.id %>" data-year="<%= cert.year %>"
                                        data-nombre="<%- encodeURIComponent(cert.nombre) %>"
                                        data-order="<%= cert.order_index %>">
                                        <td><%= cert.nombre %></td>
                                        <td><%= cert.order_index %></td>
                                        <td style="text-align:right">
                                            <button class="btn btn-secondary btn-sm" onclick="editCertFromRow(this)"><i class="fas fa-edit"></i></button>
                                            <button class="btn btn-danger btn-sm" onclick="deleteCert(<%= cert.id %>)"><i class="fas fa-trash"></i></button>
                                        </td>
                                    </tr>
                                <% }); %>
                                </tbody>
                            </table>
                            <% } %>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>

            <!-- ═══ COMMITMENT PANEL ═══ -->
            <div class="panel" id="panel-commitment">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-heart"></i> Compromiso Social</h3>
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            <button class="btn btn-danger" onclick="clearCommitment()">
                                <i class="fas fa-trash-alt"></i> Limpiar Todo
                            </button>
                            <button class="btn btn-gold" onclick="openCommitmentModal()">
                                <i class="fas fa-plus"></i> Agregar
                            </button>
                        </div>
                    </div>

                    <div class="commitment-grid" id="commitmentGrid">
                        <% commitments.forEach(function(item) { %>
                            <div class="commitment-card" data-id="<%= item.id %>"
                                data-title="<%- encodeURIComponent(item.title) %>"
                                data-desc="<%- encodeURIComponent(item.description || '') %>"
                                data-image="<%- encodeURIComponent(item.image_url || '') %>"
                                data-order="<%= item.order_index %>">
                                <% let commImageUrl = item.image_url;
                                   if (commImageUrl && commImageUrl.includes('/api/v1/storage/files/')) {
                                       const fileId = commImageUrl.split('/api/v1/storage/files/')[1].split('?')[0];
                                       commImageUrl = `/api/storage/files/${fileId}`;
                                   }
                                   if (commImageUrl) { %>
                                    <img src="<%= commImageUrl %>" alt="<%= item.title %>">
                                <% } %>
                                <div class="card-body">
                                    <h4><%= item.title %></h4>
                                    <p><%= item.description %></p>
                                    <div class="card-actions">
                                        <button class="btn btn-secondary btn-sm" onclick="editCommFromCard(this)">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>
                                        <button class="btn btn-danger btn-sm" onclick="deleteCommitment(<%= item.id %>)">
                                            <i class="fas fa-trash"></i> Eliminar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            </div>

            <!-- ═══ PROJECTS PANEL ═══ -->
            <div class="panel" id="panel-projects">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-code"></i> Proyectos de Alumnos</h3>
                        <button class="btn btn-gold" onclick="openProjectModal()">
                            <i class="fas fa-plus"></i> Agregar Proyecto
                        </button>
                    </div>

                    <div class="filter-tabs">
                        <button class="filter-tab active" onclick="filterProjects('all', this)">Todos</button>
                        <button class="filter-tab" onclick="filterProjects(1, this)">1° Año</button>
                        <button class="filter-tab" onclick="filterProjects(2, this)">2° Año</button>
                        <button class="filter-tab" onclick="filterProjects(3, this)">3° Año</button>
                    </div>

                    <div class="admin-project-grid" id="projectsGrid">
                        <% projects.forEach(function(p) { %>
                            <div class="admin-project-card" data-id="<%= p.id %>" data-year="<%= p.year %>"
                                data-proj="<%- encodeURIComponent(JSON.stringify(p)) %>">
                                <div class="admin-project-card-header">
                                    <% let adminPhotoUrl = p.student_photo_url;
                                       if (adminPhotoUrl && adminPhotoUrl.includes('/api/v1/storage/files/')) {
                                           const fileId = adminPhotoUrl.split('/api/v1/storage/files/')[1].split('?')[0];
                                           adminPhotoUrl = `/api/storage/files/${fileId}`;
                                       }
                                       if (adminPhotoUrl) { %>
                                        <img src="<%= adminPhotoUrl %>" alt="<%= p.student_name %>">
                                    <% } else { %>
                                        <div class="placeholder-photo"><i class="fas fa-user"></i></div>
                                    <% } %>
                                    <div>
                                        <h4><%= p.project_name %></h4>
                                        <span class="subtitle"><%= p.student_name %> · <span class="year-badge y<%= p.year %>"><%= p.year %>° Año</span></span>
                                    </div>
                                </div>
                                <p class="desc"><%= p.project_description %></p>
                                <div class="card-actions">
                                    <button class="btn btn-secondary btn-sm" onclick="editProjFromCard(this)">
                                        <i class="fas fa-edit"></i> Editar
                                    </button>
                                    <button class="btn btn-danger btn-sm" onclick="deleteProject(<%= p.id %>)">
                                        <i class="fas fa-trash"></i> Eliminar
                                    </button>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            </div>

            <!-- ═══ TESTIMONIOS PANEL ═══ -->
            <div class="panel" id="panel-testimonios">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-video"></i> Testimonios de Ex Alumnos</h3>
                        <button class="btn btn-gold" onclick="openTestimonioModal()">
                            <i class="fas fa-plus"></i> Agregar Testimonio
                        </button>
                    </div>

                    <div class="admin-project-grid" id="testimoniosGrid">
                        <% testimonios.forEach(function(t) { %>
                            <div class="admin-project-card" data-id="<%= t.id %>" data-testi="<%- encodeURIComponent(JSON.stringify(t)) %>">
                                <div class="admin-project-card-header">
                                    <div class="placeholder-photo"><i class="fas fa-user-graduate"></i></div>
                                    <div>
                                        <h4><%= t.student_name %></h4>
                                        <span class="subtitle"><%= t.student_role %></span>
                                    </div>
                                    <div style="margin-left: auto;">
                                        <button class="btn btn-secondary btn-sm" onclick="editTestimonio(this.closest('.admin-project-card'))" title="Editar"><i class="fas fa-edit"></i></button>
                                        <button class="btn btn-danger btn-sm" onclick="deleteTestimonio('<%= t.id %>')" title="Eliminar"><i class="fas fa-trash"></i></button>
                                    </div>
                                </div>
                                <% if(t.video_url) { %>
                                    <div style="font-size:0.8rem;color:#888;margin-top:10px;"><i class="fas fa-play-circle"></i> <%= t.video_url %></div>
                                <% } %>
                            </div>
                        <% }); %>
                    </div>
                </div>
            </div>

            <!-- ═══ DIPLOMATURAS PANEL ═══ -->
            <div class="panel" id="panel-diplomaturas">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-graduation-cap"></i> Diplomaturas y Cursos</h3>
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items:center;">
                          <!--  <button class="btn btn-outline-info btn-sm" onclick="initTables()" title="Crear tablas en la base de datos si no existen">
                                <i class="fas fa-database"></i> Inicializar BD
                            </button>-->
                            <button class="btn btn-gold" onclick="openDiplomModal()">
                                <i class="fas fa-plus"></i> Nueva Diplomatura
                            </button>
                        </div>
                    </div>

                    <% if (diplomaturas.length === 0) { %>
                        <div style="text-align:center; padding: 3rem; color: #999;">
                            <i class="fas fa-graduation-cap" style="font-size:3rem; opacity:0.3; display:block; margin-bottom:1rem;"></i>
                            <p>No hay diplomaturas publicadas aún. ¡Agregá la primera!</p>
                            <p style="font-size:0.85rem; margin-top:0.5rem;">Si es la primera vez, hacé clic en <strong>Inicializar BD</strong> primero.</p>
                        </div>
                    <% } else { %>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Fecha Inicio</th>
                                    <th>Destacado</th>
                                    <th>Orden</th>
                                    <th style="text-align:right">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="diplomaturasTable">
                                <% diplomaturas.forEach(function(d) { %>
                                    <tr data-id="<%= d.id %>" data-diplom="<%- encodeURIComponent(JSON.stringify(d)) %>">
                                        <td><strong><%= d.nombre %></strong></td>
                                        <td><%= d.fecha_inicio || '–' %></td>
                                        <td>
                                            <span class="year-badge <%= d.destacado ? 'y1' : '' %>" style="<%= d.destacado ? '' : 'background:#ddd;color:#666' %>">
                                                <%= d.destacado ? 'Sí' : 'No' %>
                                            </span>
                                        </td>
                                        <td><%= d.order_index %></td>
                                        <td style="text-align:right">
                                            <button class="btn btn-secondary btn-sm" onclick="editDiplomFromRow(this)">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-danger btn-sm" onclick="deleteDiplomatura(<%= d.id %>)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } %>
                </div>
            </div>

            <!-- ═══ PASANTÍAS PANEL ═══ -->
            <div class="panel" id="panel-pasantias">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-building"></i> Empresas de Pasantías</h3>
                        <button class="btn btn-gold" onclick="openPasantiaModal()">
                            <i class="fas fa-plus"></i> Agregar Empresa
                        </button>
                    </div>

                    <% if (pasantias.length === 0) { %>
                        <div style="text-align:center; padding: 3rem; color: #999;">
                            <i class="fas fa-building" style="font-size:3rem; opacity:0.3; display:block; margin-bottom:1rem;"></i>
                            <p>No hay empresas agregadas aún. ¡Agregá la primera!</p>
                        </div>
                    <% } else { %>
                        <div class="commitment-grid" id="pasantiasGrid">
                            <% pasantias.forEach(function(e) {
                                let logoUrl = e.logo_url;
                                if (logoUrl && logoUrl.includes('/api/v1/storage/files/')) {
                                    const fileId = logoUrl.split('/api/v1/storage/files/')[1].split('?')[0];
                                    logoUrl = `/api/storage/files/${fileId}`;
                                }
                            %>
                                <div class="commitment-card" data-id="<%= e.id %>"
                                    data-nombre="<%- encodeURIComponent(e.nombre) %>"
                                    data-logo="<%- encodeURIComponent(e.logo_url || '') %>"
                                    data-order="<%= e.order_index %>"
                                    style="padding:1rem; text-align:center;">
                                    <% if (logoUrl) { %>
                                        <img src="<%= logoUrl %>" alt="<%= e.nombre %>"
                                            style="max-height:80px; max-width:140px; object-fit:contain; margin-bottom:0.5rem;">
                                    <% } else { %>
                                        <div style="height:60px; display:flex; align-items:center; justify-content:center; background:#f5f5f5; border-radius:8px; margin-bottom:0.5rem;">
                                            <i class="fas fa-image" style="font-size:2rem; color:#ccc;"></i>
                                        </div>
                                    <% } %>
                                    <div class="card-body" style="padding:0;">
                                        <h4><%= e.nombre %></h4>
                                        <div class="card-actions" style="margin-top:0.5rem;">
                                            <button class="btn btn-secondary btn-sm" onclick="editPasantiaFromCard(this)">
                                                <i class="fas fa-edit"></i> Editar
                                            </button>
                                            <button class="btn btn-danger btn-sm" onclick="deletePasantia(<%= e.id %>)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- ═══ CONFIGURACIÓN PANEL ═══ -->
            <div class="panel" id="panel-configuracion">
                <div class="panel-section">
                    <div class="panel-title">
                        <h3><i class="fas fa-cog"></i> Configuración del Sitio</h3>
                    </div>

                    <!-- Horario -->
                    <div style="margin-bottom: 2rem;">
                        <h4 style="margin-bottom:1rem; color: var(--text-primary);"><i class="fas fa-clock"></i> Horario de Atención</h4>
                        <p style="color:#888; font-size:0.9rem; margin-bottom:1.5rem;">
                            Configurá el horario de apertura y cierre de la institución por día. Si un día está cerrado, marcalo como "Cerrado".
                        </p>

                        <div id="horarioEditor">
                            <%
                            const defaultHorario = [
                                { dia: 'Lunes', abierto: true, apertura: '08:00', cierre: '20:00' },
                                { dia: 'Martes', abierto: true, apertura: '08:00', cierre: '20:00' },
                                { dia: 'Miércoles', abierto: true, apertura: '08:00', cierre: '20:00' },
                                { dia: 'Jueves', abierto: true, apertura: '08:00', cierre: '20:00' },
                                { dia: 'Viernes', abierto: true, apertura: '08:00', cierre: '20:00' },
                                { dia: 'Sábado', abierto: true, apertura: '09:00', cierre: '13:00' },
                                { dia: 'Domingo', abierto: false, apertura: '', cierre: '' }
                            ];
                            const horarioData = horario || defaultHorario;
                            horarioData.forEach(function(dia, idx) {
                            %>
                            <div class="horario-editor-row" id="hrow-<%= idx %>">
                                <div class="horario-editor-dia">
                                    <label class="toggle-label">
                                        <input type="checkbox" class="horario-check" data-idx="<%= idx %>"
                                            <%= dia.abierto ? 'checked' : '' %>
                                            onchange="toggleHorarioDia(<%= idx %>)">
                                        <span class="toggle-slider"></span>
                                    </label>
                                    <span class="horario-editor-dia-name"><%= dia.dia %></span>
                                </div>
                                <div class="horario-editor-horas" id="horas-<%= idx %>" style="<%= dia.abierto ? '' : 'opacity:0.4; pointer-events:none;' %>">
                                    <div style="display:flex; align-items:center; gap:0.5rem;">
                                        <label style="font-size:0.8rem; color:#888;">Apertura</label>
                                        <input type="time" class="horario-time" id="apertura-<%= idx %>"
                                            value="<%= dia.apertura || '08:00' %>">
                                    </div>
                                    <span style="color:#aaa;">–</span>
                                    <div style="display:flex; align-items:center; gap:0.5rem;">
                                        <label style="font-size:0.8rem; color:#888;">Cierre</label>
                                        <input type="time" class="horario-time" id="cierre-<%= idx %>"
                                            value="<%= dia.cierre || '20:00' %>">
                                    </div>
                                </div>
                                <span id="cerrado-label-<%= idx %>" style="color:#aaa; font-size:0.9rem; <%= dia.abierto ? 'display:none' : '' %>">Cerrado</span>
                            </div>
                            <% }); %>
                        </div>

                        <button class="btn btn-gold" style="margin-top:1.5rem;" onclick="saveHorario()">
                            <i class="fas fa-save"></i> Guardar Horario
                        </button>
                    </div>
