        async function deletePasantia(id) {
            if (!confirm('¿Eliminar esta empresa?')) return;
            try { await apiCall('/admin/api/pasantias/' + id, 'DELETE'); showToast('Eliminada'); location.reload(); }
            catch (err) { showToast('Error al eliminar', 'error'); }
        }

        // ─── HORARIO ─────────────────────────────────
        function toggleHorarioDia(idx) {
            const checked = document.getElementById('panel-configuracion').querySelector(`[data-idx="${idx}"]`).checked;
            const horasDiv = document.getElementById('horas-' + idx);
            const cerradoLabel = document.getElementById('cerrado-label-' + idx);
            horasDiv.style.opacity = checked ? '1' : '0.4';
            horasDiv.style.pointerEvents = checked ? 'all' : 'none';
            if (cerradoLabel) cerradoLabel.style.display = checked ? 'none' : 'inline';
        }

        async function saveHorario() {
            const dias = ['Lunes','Martes','Miércoles','Jueves','Viernes','Sábado','Domingo'];
            const horario = dias.map((dia, idx) => {
                const check = document.querySelector(`#horarioEditor [data-idx="${idx}"]`);
                const abierto = check ? check.checked : false;
                const apertura = document.getElementById('apertura-' + idx)?.value || '';
                const cierre = document.getElementById('cierre-' + idx)?.value || '';
                return { dia, abierto, apertura, cierre };
            });
            try {
                await apiCall('/admin/api/configuracion', 'PUT', { horario });
                showToast('✓ Horario guardado correctamente');
            } catch (err) {
                showToast('Error al guardar horario', 'error');
            }
        }

        // ─── INIT BD ─────────────────────────────────
        async function initTables() {
            if (!confirm('Esto creará las tablas necesarias en la base de datos si no existen. ¿Continuar?')) return;
            try {
                const res = await fetch('/admin/api/init-tables', { method: 'POST' });
                const data = await res.json();
                if (data.success) { showToast('✓ Tablas creadas correctamente'); setTimeout(() => location.reload(), 1500); }
                else showToast('Error: ' + (data.error || 'desconocido'), 'error');
            } catch (err) { showToast('Error de conexión', 'error'); }
        }

        // ─── Sidebar mobile ───────────────────────────
        (function () {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            const toggleBtn = document.getElementById('mobileToggle');
            function openSidebar() { sidebar.classList.add('open'); overlay.classList.add('active'); document.body.classList.add('sidebar-open'); }
            function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('active'); document.body.classList.remove('sidebar-open'); }
            toggleBtn.addEventListener('click', function (e) { e.stopPropagation(); sidebar.classList.contains('open') ? closeSidebar() : openSidebar(); });
            overlay.addEventListener('click', closeSidebar);
            sidebar.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', function () { if (window.innerWidth <= 768) closeSidebar(); });
            });
        })();
    </script>

    <style>
        /* Horario editor styles */
        .horario-editor-row {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #f0f0f0;
            flex-wrap: wrap;
        }
        .horario-editor-row:last-child { border-bottom: none; }
        .horario-editor-dia { display: flex; align-items: center; gap: 0.75rem; min-width: 130px; }
        .horario-editor-dia-name { font-weight: 600; font-size: 0.9rem; }
        .horario-editor-horas { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; transition: opacity 0.2s; }
        .horario-time {
            border: 1px solid #ddd; border-radius: 6px; padding: 0.35rem 0.5rem;
            font-size: 0.9rem; font-family: inherit; background: #f9f9f9;
        }
        .toggle-label { position: relative; display: inline-block; width: 42px; height: 24px; cursor: pointer; }
        .toggle-label input { opacity: 0; width: 0; height: 0; }
        .toggle-slider {
            position: absolute; inset: 0; background: #ccc; border-radius: 24px;
            transition: 0.3s;
        }
        .toggle-slider::before {
            content: ''; position: absolute; height: 18px; width: 18px;
            left: 3px; bottom: 3px; background: white; border-radius: 50%;
            transition: 0.3s;
        }
        .toggle-label input:checked + .toggle-slider { background: #c39215; }
        .toggle-label input:checked + .toggle-slider::before { transform: translateX(18px); }
        .btn-outline-info {
            background: transparent; border: 1px solid #3b82f6; color: #3b82f6;
            font-size: 0.8rem; padding: 0.4rem 0.75rem;
        }
        .btn-outline-info:hover { background: #3b82f6; color: white; }
    </style>
