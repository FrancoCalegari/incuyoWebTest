    <!-- Toast -->
    <div class="toast" id="toast"></div>

    <script>
        // ─── Navigation ─────────────────────────────
        document.querySelectorAll('.sidebar-nav a').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                document.querySelectorAll('.sidebar-nav a').forEach(l => l.classList.remove('active'));
                link.classList.add('active');
                document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
                document.getElementById('panel-' + link.dataset.panel).classList.add('active');
                document.querySelector('.sidebar').classList.remove('open');
            });
        });

        // ─── Toast ───────────────────────────────────
        function showToast(msg, type = 'success') {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.className = 'toast ' + type + ' show';
            setTimeout(() => t.classList.remove('show'), 3000);
        }

        // ─── Modal Controls ─────────────────────────
        function closeModal(id) { document.getElementById(id).classList.remove('active'); }
        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) overlay.classList.remove('active');
            });
        });

        // ─── API Helper ─────────────────────────────
        async function apiCall(url, method = 'GET', body = null) {
            const opts = { method, headers: { 'Content-Type': 'application/json' } };
            if (body) opts.body = JSON.stringify(body);
            const res = await fetch(url, opts);
            return res.json();
        }

        // ─── File Upload ────────────────────────────
        let pendingUploads = 0;
        async function previewFile(input, previewId, hiddenId) {
            const file = input.files[0];
            if (!file) return;
            const preview = document.getElementById(previewId);
            const reader = new FileReader();
            reader.onload = (e) => {
                preview.innerHTML = '<img src="' + e.target.result + '">';
                preview.style.display = 'block';
            };
            reader.readAsDataURL(file);
            document.getElementById(hiddenId).value = '';
            pendingUploads++;
            document.querySelectorAll('.modal-overlay.active .btn-gold[type="submit"]').forEach(btn => {
                btn.disabled = true;
                btn.dataset.origText = btn.textContent;
                btn.textContent = '⏳ Subiendo imagen...';
            });
            const form = new FormData();
            form.append('file', file);
            try {
                const res = await fetch('/admin/api/upload', { method: 'POST', body: form });
                const data = await res.json();
                if (data.success && data.file) {
                    document.getElementById(hiddenId).value = data.file.url;
                    showToast('✓ Imagen subida correctamente');
                } else {
                    showToast('Error al subir imagen: ' + (data.error || 'desconocido'), 'error');
                }
            } catch (err) {
                showToast('Error de conexión al subir imagen', 'error');
            } finally {
                pendingUploads--;
                document.querySelectorAll('.modal-overlay.active .btn-gold[type="submit"]').forEach(btn => {
                    btn.disabled = false;
                    btn.textContent = btn.dataset.origText || 'Guardar';
                });
            }
        }

        // ─── CURRICULUM ─────────────────────────────
        function openCurriculumModal(id, year, name, order) {
            document.getElementById('currId').value = id || '';
            document.getElementById('currYear').value = year || 1;
            document.getElementById('currName').value = name || '';
            document.getElementById('currOrder').value = order || 0;
            document.getElementById('currModalTitle').textContent = id ? 'Editar Materia' : 'Agregar Materia';
            document.getElementById('curriculumModal').classList.add('active');
        }
        function editCurrFromRow(btn) {
            const tr = btn.closest('tr');
            openCurriculumModal(tr.dataset.id, tr.dataset.year, decodeURIComponent(tr.dataset.name), tr.dataset.order);
        }
        async function saveCurriculum(e) {
            e.preventDefault();
            const id = document.getElementById('currId').value;
            const data = {
                year: parseInt(document.getElementById('currYear').value),
                subject_name: document.getElementById('currName').value,
                order_index: parseInt(document.getElementById('currOrder').value) || 0,
            };
            try {
                if (id) { await apiCall('/admin/api/curriculum/' + id, 'PUT', data); showToast('Materia actualizada'); }
                else { await apiCall('/admin/api/curriculum', 'POST', data); showToast('Materia agregada'); }
                closeModal('curriculumModal');
                location.reload();
            } catch (err) { showToast('Error al guardar', 'error'); }
        }
        async function deleteCurriculum(id) {
            if (!confirm('¿Eliminar esta materia?')) return;
            try { await apiCall('/admin/api/curriculum/' + id, 'DELETE'); showToast('Materia eliminada'); location.reload(); }
            catch (err) { showToast('Error al eliminar', 'error'); }
        }
        async function clearCurriculum() {
            if (!confirm('⚠️ ¿Eliminar TODO el plan de estudios? Esta acción no se puede deshacer.')) return;
            try { await apiCall('/admin/api/curriculum/all', 'DELETE'); showToast('Plan de estudios vaciado'); location.reload(); }
            catch (err) { showToast('Error', 'error'); }
        }
        function filterCurriculum(year, btn) {
            document.querySelectorAll('#panel-curriculum .filter-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll('#curriculumTable tr').forEach(tr => {
                tr.style.display = (year === 'all' || tr.dataset.year == year) ? '' : 'none';
            });
        }

        // ─── COMMITMENT ─────────────────────────────
        function openCommitmentModal(id, title, desc, imageUrl, order) {
            document.getElementById('commId').value = id || '';
            document.getElementById('commTitle').value = title || '';
            document.getElementById('commDesc').value = desc || '';
            document.getElementById('commImageUrl').value = imageUrl || '';
            document.getElementById('commImageUrlManual').value = imageUrl || '';
            document.getElementById('commOrder').value = order || 0;
            document.getElementById('commImagePreview').style.display = 'none';
            document.getElementById('commModalTitle').textContent = id ? 'Editar Compromiso' : 'Agregar Compromiso';
            document.getElementById('commitmentModal').classList.add('active');
        }
        function editCommFromCard(btn) {
            const card = btn.closest('.commitment-card');
            openCommitmentModal(card.dataset.id, decodeURIComponent(card.dataset.title), decodeURIComponent(card.dataset.desc), decodeURIComponent(card.dataset.image), card.dataset.order);
