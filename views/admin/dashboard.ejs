        async function uploadTestimonioVideo(e) {
            const file = e.target.files[0];
            if(!file) return;
            const status = document.getElementById('testimonioUploadStatus');
            status.style.display = 'block';
            status.textContent = 'Subiendo video...';

            const formData = new FormData();
            formData.append('file', file);
            try {
                const res = await fetch('/admin/api/upload', { method: 'POST', body: formData });
                if (!res.ok) {
                    const text = await res.text();
                    throw new Error(text);
                }
                const data = await res.json();
                if(data.success && data.file && data.file.url) {
                    document.getElementById('testimonioVideoUrl').value = data.file.url;
                    status.textContent = '¡Video subido correctamente!';
                    setTimeout(() => { status.style.display = 'none'; }, 3000);
                } else {
                    status.textContent = 'Error: ' + (data.error || 'Fallo en la subida');
                }
            } catch(err) {
                status.textContent = 'Error: ' + err.message;
            }
        }

