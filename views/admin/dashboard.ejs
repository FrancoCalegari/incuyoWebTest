        async function saveCommitment(e) {
            e.preventDefault();
            if (pendingUploads > 0) { showToast('⏳ Esperá, la imagen se está subiendo...', 'error'); return; }
            const id = document.getElementById('commId').value;
            const data = {
                title: document.getElementById('commTitle').value,
                description: document.getElementById('commDesc').value,
                image_url: document.getElementById('commImageUrl').value || document.getElementById('commImageUrlManual').value,
                order_index: parseInt(document.getElementById('commOrder').value) || 0,
            };
            try {
                if (id) { await apiCall('/admin/api/commitment/' + id, 'PUT', data); showToast('Compromiso actualizado'); }
                else { await apiCall('/admin/api/commitment', 'POST', data); showToast('Compromiso agregado'); }
                closeModal('commitmentModal'); location.reload();
            } catch (err) { showToast('Error al guardar', 'error'); }
        }
        async function deleteCommitment(id) {
            if (!confirm('¿Eliminar este compromiso?')) return;
            try { await apiCall('/admin/api/commitment/' + id, 'DELETE'); showToast('Eliminado'); location.reload(); }
            catch (err) { showToast('Error al eliminar', 'error'); }
        }
        async function clearCommitment() {
            if (!confirm('⚠️ ¿Eliminar todo el compromiso social?')) return;
            try { await apiCall('/admin/api/commitment/all', 'DELETE'); showToast('Vaciado'); location.reload(); }
            catch (err) { showToast('Error', 'error'); }
        }

        // ─── PROJECTS ───────────────────────────────
        function openProjectModal(data) {
