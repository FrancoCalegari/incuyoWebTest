            document.getElementById('projId').value = d.id || '';
            document.getElementById('projStudentName').value = d.student_name || '';
            document.getElementById('projYear').value = d.year || 1;
            document.getElementById('projStudentPhoto').value = d.student_photo_url || '';
            document.getElementById('projStudentPhotoManual').value = d.student_photo_url || '';
            document.getElementById('projName').value = d.project_name || '';
            document.getElementById('projIcon').value = d.project_icon || 'fas fa-code';
            document.getElementById('projDesc').value = d.project_description || '';
            document.getElementById('projImageUrl').value = d.project_image_url || '';
            document.getElementById('projImageUrlManual').value = d.project_image_url || '';
            document.getElementById('projDemoUrl').value = d.project_demo_url || '';
            document.getElementById('projTech').value = (d.tech_tags_arr || []).join(', ');
            document.getElementById('projOrder').value = d.order_index || 0;
            document.getElementById('projPhotoPreview').style.display = 'none';
            document.getElementById('projImagePreview').style.display = 'none';
            document.getElementById('projModalTitle').textContent = d.id ? 'Editar Proyecto' : 'Agregar Proyecto';
            document.getElementById('projectModal').classList.add('active');
        }
        function editProjFromCard(btn) {
            const card = btn.closest('.admin-project-card');
            openProjectModal(JSON.parse(decodeURIComponent(card.dataset.proj)));
        }
        async function saveProject(e) {
            e.preventDefault();
            if (pendingUploads > 0) { showToast('⏳ Esperá...', 'error'); return; }
            const id = document.getElementById('projId').value;
            const techStr = document.getElementById('projTech').value;
            const data = {
                student_name: document.getElementById('projStudentName').value,
                student_photo_url: document.getElementById('projStudentPhoto').value || document.getElementById('projStudentPhotoManual').value,
                year: parseInt(document.getElementById('projYear').value),
                project_name: document.getElementById('projName').value,
                project_icon: document.getElementById('projIcon').value,
                project_description: document.getElementById('projDesc').value,
                project_image_url: document.getElementById('projImageUrl').value || document.getElementById('projImageUrlManual').value,
                project_demo_url: document.getElementById('projDemoUrl').value,
                tech_tags: JSON.stringify(techStr.split(',').map(t => t.trim()).filter(Boolean)),
                order_index: parseInt(document.getElementById('projOrder').value) || 0,
            };
            try {
                if (id) { await apiCall('/admin/api/projects/' + id, 'PUT', data); showToast('Proyecto actualizado'); }
                else { await apiCall('/admin/api/projects', 'POST', data); showToast('Proyecto agregado'); }
                closeModal('projectModal'); location.reload();
            } catch (err) { showToast('Error al guardar', 'error'); }
        }
        async function deleteProject(id) {
            if (!confirm('¿Eliminar este proyecto?')) return;
            try { await apiCall('/admin/api/projects/' + id, 'DELETE'); showToast('Eliminado'); location.reload(); }
            catch (err) { showToast('Error al eliminar', 'error'); }
        }
        function filterProjects(year, btn) {
            document.querySelectorAll('#panel-projects .filter-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll('.admin-project-card').forEach(card => {
                card.style.display = (year === 'all' || card.dataset.year == year) ? '' : 'none';
            });
        }

        // ─── DIPLOMATURAS ────────────────────────────
        function openDiplomModal(data) {
            const d = data || {};
            document.getElementById('diplomId').value = d.id || '';
            document.getElementById('diplomNombre').value = d.nombre || '';
            document.getElementById('diplomDescBreve').value = d.descripcion_breve || '';
            document.getElementById('diplomDescCompleta').value = d.descripcion_completa || '';
            document.getElementById('diplomImgUrl').value = d.imagen_url || '';
            document.getElementById('diplomImgUrlManual').value = d.imagen_url || '';
            document.getElementById('diplomFecha').value = d.fecha_inicio || '';
            document.getElementById('diplomWA').value = d.whatsapp_msg || '';
            document.getElementById('diplomOrder').value = d.order_index || 0;
            document.getElementById('diplomDestacado').checked = !!d.destacado;
            document.getElementById('diplomImgPreview').style.display = 'none';
            document.getElementById('diplomModalTitle').textContent = d.id ? 'Editar Diplomatura' : 'Nueva Diplomatura';
            document.getElementById('diplomModal').classList.add('active');
        }
        function editDiplomFromRow(btn) {
            const tr = btn.closest('tr');
            openDiplomModal(JSON.parse(decodeURIComponent(tr.dataset.diplom)));
        }
        async function saveDiplomatura(e) {
            e.preventDefault();
            if (pendingUploads > 0) { showToast('⏳ Esperá, la imagen se está subiendo...', 'error'); return; }
            const id = document.getElementById('diplomId').value;
            const data = {
                nombre: document.getElementById('diplomNombre').value,
                descripcion_breve: document.getElementById('diplomDescBreve').value,
                descripcion_completa: document.getElementById('diplomDescCompleta').value,
                imagen_url: document.getElementById('diplomImgUrl').value || document.getElementById('diplomImgUrlManual').value,
                fecha_inicio: document.getElementById('diplomFecha').value,
                whatsapp_msg: document.getElementById('diplomWA').value,
                order_index: parseInt(document.getElementById('diplomOrder').value) || 0,
                destacado: document.getElementById('diplomDestacado').checked ? 1 : 0,
            };
            try {
                if (id) { await apiCall('/admin/api/diplomaturas/' + id, 'PUT', data); showToast('Diplomatura actualizada'); }
                else { await apiCall('/admin/api/diplomaturas', 'POST', data); showToast('Diplomatura creada'); }
                closeModal('diplomModal'); location.reload();
            } catch (err) { showToast('Error al guardar', 'error'); }
        }
        async function deleteDiplomatura(id) {
            if (!confirm('¿Eliminar esta diplomatura?')) return;
            try { await apiCall('/admin/api/diplomaturas/' + id, 'DELETE'); showToast('Eliminada'); location.reload(); }
            catch (err) { showToast('Error al eliminar', 'error'); }
        }

        // ─── PASANTÍAS ───────────────────────────────
        function openPasantiaModal(data) {
            const d = data || {};
            document.getElementById('pasantiaId').value = d.id || '';
            document.getElementById('pasantiaNombre').value = d.nombre || '';
            document.getElementById('pasantiaLogoUrl').value = d.logo_url || '';
            document.getElementById('pasantiaLogoUrlManual').value = d.logo_url || '';
            document.getElementById('pasantiaOrder').value = d.order_index || 0;
            document.getElementById('pasantiaLogoPreview').style.display = 'none';
            document.getElementById('pasantiaModalTitle').textContent = d.id ? 'Editar Empresa' : 'Agregar Empresa';
