<!doctype html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Diplomaturas y Cursos del Instituto INCUYO - Formación continua en tecnología, programación e inteligencia artificial en Mendoza, Argentina." />
    <title>Diplomaturas y Cursos — Instituto Nuevo Cuyo INCUYO</title>
    <meta name="theme-color" content="#10182c" />
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>

<body>
    <!-- NAVIGATION -->
    <nav class="navbar" id="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <img src="/assets/img/logo.png" alt="Instituto Nuevo Cuyo" class="navbar-logo" />
            </a>
            <button class="navbar-toggle" id="navbarToggle" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul class="navbar-menu" id="navbarMenu">
                <li><a href="/">Inicio</a></li>
                <li><a href="/#inscripciones">Inscripciones</a></li>
                <li><a href="/proyectosalumnos">Proyectos</a></li>
                <li><a href="/diplomaturas" class="campus-link">Diplomaturas</a></li>
                <li>
                    <a href="https://aula.incuyo.edu.ar/" target="_blank" class="campus-link">Campus Virtual</a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- PAGE HERO -->
    <section class="diplom-page-hero">
        <div class="container">
            <p class="section-subtitle" style="color: var(--primary-gold);">Formación Continua</p>
            <h1 class="diplom-page-title">Diplomaturas y Cursos</h1>
            <p class="diplom-page-desc">Ampliá tus conocimientos con nuestras diplomaturas y cursos especializados en tecnología, programación e inteligencia artificial.</p>
            <a href="https://wa.me/5492616271658?text=Hola!%20Me%20interesa%20información%20sobre%20las%20diplomaturas%20de%20INCUYO"
                class="btn btn-gold btn-lg" target="_blank">
                <i class="fab fa-whatsapp"></i> Consultá por WhatsApp
            </a>
        </div>
    </section>

    <!-- DIPLOMATURAS GRID -->
    <section class="section" style="background: var(--gray-100);">
        <div class="container">
            <% if (diplomaturas.length === 0) { %>
                <div class="diplom-empty">
                    <i class="fas fa-graduation-cap"></i>
                    <h3>Próximamente</h3>
                    <p>Estamos preparando nuestras diplomaturas y cursos. ¡Consultanos por WhatsApp para estar al tanto de las novedades!</p>
                    <a href="https://wa.me/5492616271658?text=Hola!%20Quiero%20saber%20cuándo%20empiezan%20las%20diplomaturas"
                        class="btn btn-gold btn-lg" target="_blank">
                     Consultá
                    </a>
                </div>
            <% } else { %>
                <div class="diplom-full-grid">
                    <% diplomaturas.forEach(function(d, idx) { %>
                        <article class="diplom-card-full" id="curso-<%= d.id %>" onclick="openDiplomModal(<%= idx %>)">
                            <% if (d.imagen_url) { %>
                                <div class="diplom-card-img">
                                    <img src="<%= d.imagen_url %>" alt="<%= d.nombre %>" loading="lazy" />
                                </div>
                            <% } else { %>
                                <div class="diplom-card-img diplom-card-img--placeholder">
                                    <i class="fas fa-graduation-cap"></i>
                                </div>
                            <% } %>
                            <div class="diplom-card-body">
                                <% if (d.fecha_inicio) { %>
                                    <span class="diplom-badge-inicio">
                                        <i class="fas fa-calendar-alt"></i> Inicio: <%= d.fecha_inicio %>
                                    </span>
                                <% } %>
                                <h2 class="diplom-card-title"><%= d.nombre %></h2>
                                <p class="diplom-card-desc"><%= d.descripcion_breve %></p>
                                <button class="btn btn-primary diplom-ver-btn">
                                    <i class="fas fa-eye"></i> Ver Diplomatura
                                </button>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </section>

    <!-- ─── MODALES DE DETALLE ─── -->
    <% diplomaturas.forEach(function(d, idx) { %>
        <div class="diplom-modal-overlay" id="modal-<%= idx %>" onclick="closeDiplomModal(<%= idx %>)">
            <div class="diplom-modal" onclick="event.stopPropagation()">
                <button class="diplom-modal-close" onclick="closeDiplomModal(<%= idx %>)">
                    <i class="fas fa-times"></i>
                </button>
                <% if (d.imagen_url) { %>
                    <div class="diplom-modal-img">
                        <img src="<%= d.imagen_url %>" alt="<%= d.nombre %>" />
                    </div>
                <% } %>
                <div class="diplom-modal-body">
                    <% if (d.fecha_inicio) { %>
                        <span class="diplom-badge-inicio">
                            <i class="fas fa-calendar-alt"></i> Inicio: <%= d.fecha_inicio %>
                        </span>
                    <% } %>
                    <h2 class="diplom-modal-title"><%= d.nombre %></h2>
                    <div class="diplom-modal-desc">
                        <%- (d.descripcion_completa || d.descripcion_breve || '').replace(/\n/g, '<br>') %>
                    </div>
                    <a href="https://wa.me/5492616271658?text=<%= encodeURIComponent(d.whatsapp_msg || 'Hola! Me interesa la diplomatura: ' + d.nombre) %>"
                        class="btn btn-whatsapp btn-lg" target="_blank">
                        <i class="fab fa-whatsapp"></i> Consultar por WhatsApp
                    </a>
                </div>
            </div>
        </div>
    <% }); %>

    <!-- FOOTER -->
    <footer class="footer" id="contacto">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>INCUYO</h3>
                    <p>Instituto de Estudios Superiores Nuevo Cuyo PT-169</p>
                </div>
                <div class="footer-section">
                    <h3>Navegación</h3>
                    <p><a href="/">Inicio</a></p>
                    <p><a href="/diplomaturas">Diplomaturas</a></p>
                    <p><a href="/proyectosalumnos">Proyectos Alumnos</a></p>
                    <p><a href="https://aula.incuyo.edu.ar/" target="_blank">Campus Virtual</a></p>
                </div>
                <div class="footer-section">
                    <h3>Contacto</h3>
                    <div class="contact-item">
                        <i class="fas fa-phone contact-icon"></i>
                        <a href="tel:+5492616271658">(+054) 261 6271658</a>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-envelope contact-icon"></i>
                        <a href="mailto:incuyo@gmail.com">incuyo@gmail.com</a>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-map-marker-alt contact-icon"></i>
                        <span>La Rioja 614, Mendoza, Argentina</span>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Instituto Nuevo Cuyo - Todos los derechos reservados</p>
            </div>
        </div>
    </footer>

    <!-- WHATSAPP FLOAT -->
    <div class="whatsapp-float">
        <a href="https://wa.me/5492616271658?text=Hola!%20Me%20interesa%20información%20sobre%20las%20diplomaturas"
            class="whatsapp-btn" target="_blank" aria-label="Contactar por WhatsApp">
            <i class="fab fa-whatsapp"></i>
        </a>
    </div>

    <script>
        // Navbar scroll
        const _navbar = document.getElementById('navbar');
        const _navMenu = document.getElementById('navbarMenu');
        const _navToggle = document.getElementById('navbarToggle');

        window.addEventListener('scroll', () => {
            _navbar.classList.toggle('scrolled', window.scrollY > 50);
        });

        // Hamburger — usa clase 'active' igual que script.js
        function _toggleMenu(state) {
            _navToggle.classList.toggle('active', state);
            _navMenu.classList.toggle('active', state);
        }

        _navToggle.addEventListener('click', () => _toggleMenu(!_navMenu.classList.contains('active')));

        // Cerrar al hacer clic fuera o en un link
        document.addEventListener('click', (e) => {
            if (!_navbar.contains(e.target) || e.target.tagName === 'A') _toggleMenu(false);
        });

        // Modal controls
        function openDiplomModal(idx) {
            document.getElementById('modal-' + idx).classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        function closeDiplomModal(idx) {
            document.getElementById('modal-' + idx).classList.remove('active');
            document.body.style.overflow = '';
        }
        // Cerrar con Escape
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                document.querySelectorAll('.diplom-modal-overlay.active').forEach(m => {
                    m.classList.remove('active');
                    document.body.style.overflow = '';
                });
            }
        });
    </script>
</body>
</html>
