                <li><a href="#inscripciones">Inscripciones</a></li> -->
                <li><a href="./diplomaturas">Diplomaturas</a></li>
                <li>
                    <a href="<%= config.campus_virtual_url || 'https://aula.incuyo.edu.ar/' %>" target="_blank" class="campus-link">Campus Virtual</a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="hero" id="inicio">
        <!-- Background Video -->
        <video class="hero-bg-video" autoplay muted loop playsinline>
            <source src="./012025.mp4" type="video/mp4">
            Tu navegador no soporta el elemento de video.
        </video>

        <!-- Glassmorphism Overlay -->
        <div class="hero-glass-overlay"></div>
        <div class="container">
            <div class="hero-row">
                <!-- Left: text + CTA -->
                <div class="hero-text-col">
                    <p class="hero-subtitle">
                        Instituto de Estudios Superiores Nuevo Cuyo PT-169
                    </p>
                    <h1 class="hero-title">Imagina tu Futuro<span class="typewriter-cursor">|</span></h1>
                    <p class="hero-description">
                        Conoce nuevas oportunidades en el desarrollo de software con
                        tecnologías de vanguardia e inteligencia artificial
                    </p>
                    <div class="hero-cta-group">
                        <a href="/masinfo.html" class="btn btn-gold btn-lg hero-cta-btn">
                            <i class="fas fa-graduation-cap"></i> Info Carrera Programación + IA
                        </a>
                        <!-- <a href="https://wa.me/5492616271658?text=Hola!%20Me%20interesa%20información%20sobre%20la%20Tecnicatura"
                            class="btn btn-outline-white btn-lg" target="_blank">
                            <i class="fab fa-whatsapp"></i> Consultá Ahora
                        </a> -->
                    </div>
                </div>

                <!-- Right: video -->
                <div class="hero-video-col">
                    <div class="video-wrapper">
                        <video src="./012025.mp4" title="Video Promocional - Tecnicatura en Desarrollo de Software"
                            autoplay muted loop playsinline controls>
                            Tu navegador no soporta el elemento de video.
                        </video>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ENROLLMENT SECTION (BECAS) -->
                    <section class="section section-dark enrollment" id="inscripciones">
                        <div class="container">
                            <div class="section-header">
                                <p class="section-subtitle" style="color: var(--primary-gold)">
                                    Ciclo Lectivo 2027
                                </p>
                                <h2 class="section-title">¡Inscripciones Abiertas con Becas Exclusivas!</h2>
                            </div>

                            <div class="highlight-box reveal">
                                <div class="text-center">
                                    <div class="scholarship-badge" style="margin-bottom: 1.5rem;">
                                        <i class="fas fa-graduation-cap"></i> PROGRAMA DE BECAS 2027
                                    </div>
                                    <p style="color: white; font-size: 1.125rem; margin-bottom: 2rem">
                                        Aprovechá nuestros descuentos especiales para el próximo ciclo lectivo y asegurá tu futuro en el desarrollo de software.
                                    </p>
                                </div>

                                <div class="highlight-grid">
                                    <div class="highlight-item reveal">
                                        <div class="highlight-item-icon"><i class="fas fa-sun"></i></div>
                                        <h3 style="color: white; font-size: 1.25rem; margin-bottom: 0.5rem;">Turno Mañana</h3>
                                        <p class="highlight-item-text">
                                            <strong style="color: var(--primary-gold); font-size: 1.1rem;">Hasta 50% de Beca</strong><br>
                                            Cursado intensivo y focalizado.
                                        </p>
                                    </div>

                                    <div class="highlight-item reveal">
                                        <div class="highlight-item-icon"><i class="fas fa-cloud-sun"></i></div>
                                        <h3 style="color: white; font-size: 1.25rem; margin-bottom: 0.5rem;">Turno Tarde</h3>
                                        <p class="highlight-item-text">
                                            <strong style="color: var(--primary-gold); font-size: 1.1rem;">Hasta 40% de Beca</strong><br>
                                            Ideal para combinar con otras actividades.
                                        </p>
                                    </div>

                                    <div class="highlight-item reveal">
                                        <div class="highlight-item-icon"><i class="fas fa-moon"></i></div>
                                        <h3 style="color: white; font-size: 1.25rem; margin-bottom: 0.5rem;">Turno Vespertino</h3>
                                        <p class="highlight-item-text">
                                            <strong style="color: var(--primary-gold); font-size: 1.1rem;">Hasta 40% de Beca</strong><br>
                                            Pensado para quienes trabajan de día.
                                        </p>
                                    </div>
                                </div>

                                <div class="text-center" style="margin-top: 2.5rem">
                                    <button class="btn btn-gold btn-lg" onclick="openBecaModal()" style="font-size: 1.1rem; padding: 1rem 2.5rem; animation: pulse 2s infinite;">
                                        <i class="fas fa-envelope-open-text"></i> Solicitar Beca Ahora
                                    </button>
                                    <style>
                                        @keyframes pulse {
                                            0% { box-shadow: 0 0 0 0 rgba(195, 146, 21, 0.7); }
                                            70% { box-shadow: 0 0 0 15px rgba(195, 146, 21, 0); }
                                            100% { box-shadow: 0 0 0 0 rgba(195, 146, 21, 0); }
                                        }
                                    </style>
                                </div>
                            </div>
                        </div>
                    </section>

