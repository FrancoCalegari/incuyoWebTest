    <!-- SERVICIOS TECNOLÓGICOS INTEGRALES INCUYO -->
    <section class="section servicios-incuyo" id="servicios">
        <div class="container">
            <div class="servicios-incuyo__inner reveal">
                <p class="section-subtitle" style="color: var(--white)">
                    <%= config.servicios_subtitle || 'Nuestros servicios' %>
                </p>

                <h2 class="servicios-incuyo__title"><%= config.servicios_title || 'Servicios tecnológicos integrales' %></h2>

                <p class="servicios-incuyo__lead">
                    <%= config.servicios_lead || 'Hemos formado una empresa de servicios, unificando experiencia & energía con los alumnos del último año de la carrera.' %>
                </p>

                <div class="servicios-incuyo__beneficios">
                    <h3 class="servicios-incuyo__beneficios-title">
                        <i class="fas fa-star"></i> Beneficios directos
                    </h3>

                    <div class="servicios-incuyo__grid">
                        <div class="servicios-incuyo__card">
                            <div class="servicios-incuyo__card-icon">1</div>
                            <p class="servicios-incuyo__card-text">
                                <%= config.servicios_card1 || 'Podrá contar con un alumno como pasante para guiarlo y apoyarlo en su emprendimiento.' %>
                            </p>
                        </div>

                        <div class="servicios-incuyo__card">
                            <div class="servicios-incuyo__card-icon">2</div>
                            <p class="servicios-incuyo__card-text">
                                <%= config.servicios_card2 || 'Luego que el proyecto quede finalizado, con su aprobación (puede contratar al pasante, si lo desea; para seguir creciendo juntos).' %>
                            </p>
                        </div>

                        <div class="servicios-incuyo__card">
                            <div class="servicios-incuyo__card-icon">3</div>
                            <p class="servicios-incuyo__card-text">
                                <%= config.servicios_card3 || 'Podrá lograr objetivos, mejorar ventas al mejor costo del mercado.' %>
                            </p>
                        </div>

                        <div class="servicios-incuyo__card">
                            <div class="servicios-incuyo__card-icon">4</div>
                            <p class="servicios-incuyo__card-text">
                                <%= config.servicios_card4 || 'Garantía de satisfacción.' %>
                            </p>
                        </div>
                    </div>
                </div>

                <a href="/servicios" class="btn btn-gold btn-lg servicios-incuyo__cta">
                    <i class="fas fa-arrow-right"></i> Conoce nuestros servicios
                </a>
            </div>
        </div>
    </section>


    <!-- DIPLOMATURAS SECTION -->
    <section class="section diplomaturas-section" id="diplomaturas">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Formación Continua</p>
                <h2 class="section-title">Diplomaturas y Cursos</h2>
                <p class="section-description">
                    Ampliá tus conocimientos con nuestras diplomaturas y cursos especializados en tecnología e
                    inteligencia artificial.
                </p>
            </div>

            <% if (diplomaturas.length===0) { %>
                <div class="diplom-empty-index">
                    <i class="fas fa-graduation-cap"></i>
                    <p>Próximamente publicaremos nuestras diplomaturas y cursos.</p>
                </div>
                <% } else { %>
                    <div class="diplom-index-grid reveal">
                        <% diplomaturas.forEach(function(d, idx) { %>
                            <article class="diplom-index-card" onclick="openIndexDiplomModal(<%= idx %>)">
                                <% if (d.imagen_url) { %>
                                    <div class="diplom-index-card__img">
                                        <img src="<%= d.imagen_url %>" alt="<%= d.nombre %>" loading="lazy" />
                                    </div>
                                    <% } else { %>
                                        <div class="diplom-index-card__img diplom-index-card__img--placeholder">
                                            <i class="fas fa-graduation-cap"></i>
                                        </div>
                                        <% } %>
                                            <div class="diplom-index-card__body">
                                                <% if (d.fecha_inicio) { %>
                                                    <span class="diplom-badge-inicio">
                                                        <i class="fas fa-calendar-alt"></i> Inicio: <%= d.fecha_inicio
                                                            %>
                                                    </span>
                                                    <% } %>
                                                        <h3 class="diplom-index-card__title">
                                                            <%= d.nombre %>
                                                        </h3>
                                                        <p class="diplom-index-card__desc">
                                                            <%= d.descripcion_breve %>
                                                        </p>
                                                        <span class="diplom-ver-link"><i class="fas fa-arrow-right"></i>
                                                            Ver diplomatura</span>
                                            </div>
                            </article>
                            <% }); %>
                    </div>
                    <% } %>

                        <div class="text-center" style="margin-top: 3rem;">
                            <a href="/diplomaturas" class="btn btn-gold btn-lg">
                                <i class="fas fa-graduation-cap"></i> Ver todas las Diplomaturas
                            </a>
                        </div>
        </div>
    </section>

    <!-- MODALES DE DETALLE (index) -->
    <% diplomaturas.forEach(function(d, idx) { %>
        <div class="diplom-modal-overlay" id="idx-modal-<%= idx %>" onclick="closeIndexDiplomModal(<%= idx %>)">
            <div class="diplom-modal" onclick="event.stopPropagation()">
                <button class="diplom-modal-close" onclick="closeIndexDiplomModal(<%= idx %>)">
                    <i class="fas fa-times"></i>
                </button>
                <% if (d.imagen_url) { %>
                    <div class="diplom-modal-img">
                        <img src="<%= d.imagen_url %>" alt="<%= d.nombre %>" />
                    </div>
                    <% } %>
                        <div class="diplom-modal-body">
                            <% if (d.fecha_inicio) { %>
                                <span class="diplom-badge-inicio">
                                    <i class="fas fa-calendar-alt"></i> Inicio: <%= d.fecha_inicio %>
                                </span>
                                <% } %>
                                    <h2 class="diplom-modal-title">
                                        <%= d.nombre %>
                                    </h2>
                                    <div class="diplom-modal-desc">
                                        <%- (d.descripcion_completa || d.descripcion_breve || '' ).replace(/\n/g, '<br>'
                                            ) %>
                                    </div>
                                    <a href="https://wa.me/5492616271658?text=<%= encodeURIComponent(d.whatsapp_msg || 'Hola! Me interesa la diplomatura: ' + d.nombre) %>"
                                        class="btn btn-whatsapp btn-lg" target="_blank">
                                        <i class="fab fa-whatsapp"></i> Consultar por WhatsApp
                                    </a>
                        </div>
            </div>
        </div>
        <% }); %>

            <!-- BECA PUBLIC MODAL -->
            <div class="diplom-modal-overlay" id="publicBecaModal" style="z-index: 10000;" onclick="closeBecaModal()">
                <div class="diplom-modal" onclick="event.stopPropagation()" style="max-width: 650px; background: #fff; padding: 2rem; border-radius: 12px;">
                    <button class="diplom-modal-close" onclick="closeBecaModal()">
                        <i class="fas fa-times"></i>
                    </button>
                    
                    <h2 style="color: #10182c; margin-bottom: 1.5rem; text-align: center; font-size: 1.8rem;">
                        <i class="fas fa-graduation-cap" style="color: var(--primary-gold);"></i> Solicitud de Beca 2027
                    </h2>
                    
                    <form id="becaForm" onsubmit="submitBeca(event)">
                        <!-- Sección 1: Información Personal -->
                        <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #e2e8f0;">
                            <h3 style="color: #334155; font-size: 1.1rem; margin-bottom: 1rem;"><i class="fas fa-user"></i> 1. Información Personal</h3>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Nombre *</label>
                                    <input type="text" id="becaInputFirstName" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="Tu nombre">
                                </div>
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Apellido *</label>
                                    <input type="text" id="becaInputLastName" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="Tu apellido">
                                </div>
                            </div>
                        </div>

                        <!-- Sección 2: Motivo -->
                        <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #e2e8f0;">
                            <h3 style="color: #334155; font-size: 1.1rem; margin-bottom: 1rem;"><i class="fas fa-pen"></i> 2. Motivo de la Solicitud</h3>
                            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">¿Por qué solicitás la beca? *</label>
                            <textarea id="becaInputReason" required rows="3" style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px; resize: vertical;" placeholder="Contanos brevemente tu situación..."></textarea>
                        </div>

                        <!-- Sección 3: Contacto -->
                        <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #e2e8f0;">
                            <h3 style="color: #334155; font-size: 1.1rem; margin-bottom: 1rem;"><i class="fas fa-address-book"></i> 3. Información de Contacto</h3>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Correo Electrónico *</label>
                                    <input type="email" id="becaInputEmail" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="ejemplo@correo.com">
                                </div>
                                <div>
                                    <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Celular / WhatsApp *</label>
                                    <input type="tel" id="becaInputPhone" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="+54 9 ...">
                                </div>
                            </div>
                        </div>

                        <div style="text-align: center;">
                            <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 1rem;">Un asesor te responderá dentro de las 72 horas hábiles.</p>
                            <button type="submit" id="becaSubmitBtn" class="btn btn-gold btn-lg" style="width: 100%;">
                                Enviar Solicitud de Beca
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- PASANTÍAS SECTION -->
            <% if (pasantias.length> 0) { %>
                <section class="section pasantias-section" id="pasantias">
                    <div class="container">
                        <div class="section-header">
                            <p class="section-subtitle">Vinculación Laboral</p>
                            <h2 class="section-title">Pasantias</h2>
                            <p class="section-description">
                                Nuestros alumnos desarrollan experiencia real en empresas líderes a través de pasantías
                                y proyectos profesionales.
                            </p>
                        </div>
                    </div>
                    <!-- Carrusel igual que tech-carousel: mask-image + triple set para cubrir 1920px -->
                    <div class="pasantias-carousel-outer">
                        <div class="pasantias-carousel-track">
                            <% /* Set 1 */%>
                                <% pasantias.forEach(function(empresa) { %>
                                    <div class="pasantia-logo-item">
                                        <% if (empresa.logo_url) { %>
                                            <img src="<%= empresa.logo_url %>" alt="<%= empresa.nombre %>"
                                                title="<%= empresa.nombre %>" loading="lazy" />
                                            <% } else { %>
                                                <span class="pasantia-logo-text">
                                                    <%= empresa.nombre %>
                                                </span>
                                                <% } %>
                                    </div>
                                    <% }); %>
                                        <% /* Set 2 (copia) */%>
                                            <% pasantias.forEach(function(empresa) { %>
                                                <div class="pasantia-logo-item">
                                                    <% if (empresa.logo_url) { %>
                                                        <img src="<%= empresa.logo_url %>" alt="<%= empresa.nombre %>"
                                                            title="<%= empresa.nombre %>" loading="lazy" />
                                                        <% } else { %>
                                                            <span class="pasantia-logo-text">
                                                                <%= empresa.nombre %>
                                                            </span>
                                                            <% } %>
                                                </div>
                                                <% }); %>
                                                    <% /* Set 3 (copia) */%>
                                                        <% pasantias.forEach(function(empresa) { %>
                                                            <div class="pasantia-logo-item">
                                                                <% if (empresa.logo_url) { %>
                                                                    <img src="<%= empresa.logo_url %>"
                                                                        alt="<%= empresa.nombre %>"
                                                                        title="<%= empresa.nombre %>" loading="lazy" />
                                                                    <% } else { %>
                                                                        <span class="pasantia-logo-text">
                                                                            <%= empresa.nombre %>
                                                                        </span>
                                                                        <% } %>
                                                            </div>
                                                            <% }); %>
                        </div>
                    </div>
                </section>
                <% } %>

                    <!-- CERTIFICATIONS SECTION
                    <section class="section certifications" id="certificaciones">
                        <div class="container">
                            <div class="section-header">
