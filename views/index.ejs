<!doctype html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <meta name="description"
        content="Instituto de Estudios Superiores Nuevo Cuyo PT-169 - Tecnicatura Superior en Desarrollo de Software. Formación profesional con IA, modalidad bimodal y certificaciones laborales." />
    <meta name="keywords"
        content="tecnicatura, desarrollo software, programación, Mendoza, educación superior, IA, inteligencia artificial" />
    <meta name="author" content="Instituto Nuevo Cuyo" />
    <title>Instituto Nuevo Cuyo - Tecnicatura en Desarrollo de Software</title>

    <!-- Theme Color (barra de navegador en móvil) -->
    <meta name="theme-color" content="#10182c" />
    <meta name="msapplication-navbutton-color" content="#10182c" />
    <meta name="apple-mobile-web-app-status-bar-style" content="#10182c" />

    <!-- Open Graph / Facebook / WhatsApp / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://incuyo.edu.ar/" />
    <meta property="og:title" content="Instituto Nuevo Cuyo - Tecnicatura en Desarrollo de Software" />
    <meta property="og:description"
        content="Formá parte de la Tecnicatura Superior en Desarrollo de Software del Instituto Nuevo Cuyo PT-169. Modalidad bimodal, integración con IA y certificaciones laborales en Mendoza, Argentina." />
    <meta property="og:image" content="https://incuyo.edu.ar/img/webpreview.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Instituto Nuevo Cuyo - Tecnicatura en Desarrollo de Software" />
    <meta property="og:site_name" content="Instituto Nuevo Cuyo" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://incuyo.edu.ar/" />
    <meta name="twitter:title" content="Instituto Nuevo Cuyo - Tecnicatura en Desarrollo de Software" />
    <meta name="twitter:description"
        content="Formá parte de la Tecnicatura Superior en Desarrollo de Software del Instituto Nuevo Cuyo PT-169. Modalidad bimodal, integración con IA y certificaciones laborales en Mendoza, Argentina." />
    <meta name="twitter:image" content="https://incuyo.edu.ar/img/webpreview.png" />
    <meta name="twitter:image:alt" content="Instituto Nuevo Cuyo - Tecnicatura en Desarrollo de Software" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="/img/favicon.ico" />

    <!-- Stylesheet -->
    <link rel="stylesheet" href="/css/style.css" />

    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>

<body>
    <!-- NAVIGATION -->
    <nav class="navbar" id="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <img src="/assets/img/logo.png" alt="Instituto Nuevo Cuyo" class="navbar-logo" />
            </a>

            <button class="navbar-toggle" id="navbarToggle" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <ul class="navbar-menu" id="navbarMenu">
                <li><a href="#inicio">Inicio</a></li>
                <li><a href="#inscripciones">Inscripciones</a></li>
                <li><a href="/proyectosalumnos">Proyectos</a></li>
                <li><a href="/diplomaturas">Diplomaturas</a></li>
                <li>
                    <a href="https://aula.incuyo.edu.ar/" target="_blank" class="campus-link">Campus Virtual</a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="hero" id="inicio">
        <!-- Background Video -->
        <video class="hero-bg-video" autoplay muted loop playsinline>
            <source src="./012025.mp4" type="video/mp4">
            Tu navegador no soporta el elemento de video.
        </video>

        <!-- Glassmorphism Overlay -->
        <div class="hero-glass-overlay"></div>
        <div class="container">
            <div class="hero-row">
                <!-- Left: text + CTA -->
                <div class="hero-text-col">
                    <p class="hero-subtitle">
                        Instituto de Estudios Superiores Nuevo Cuyo PT-169
                    </p>
                    <h1 class="hero-title">Imagina tu Futuro<span class="typewriter-cursor">|</span></h1>
                    <p class="hero-description">
                        Conoce nuevas oportunidades en el desarrollo de software con
                        tecnologías de vanguardia e inteligencia artificial
                    </p>
                    <div class="hero-cta-group">
                        <a href="/masinfo.html" class="btn btn-gold btn-lg hero-cta-btn">
                            <i class="fas fa-graduation-cap"></i> Conocé la Carrera
                        </a>
                        <a href="https://wa.me/5492616271658?text=Hola!%20Me%20interesa%20información%20sobre%20la%20Tecnicatura"
                            class="btn btn-outline-white btn-lg" target="_blank">
                            <i class="fab fa-whatsapp"></i> Consultá Ahora
                        </a>
                    </div>
                </div>

                <!-- Right: video -->
                <div class="hero-video-col">
                    <div class="video-wrapper">
                        <video src="./012025.mp4" title="Video Promocional - Tecnicatura en Desarrollo de Software"
                            autoplay muted loop playsinline controls>
                            Tu navegador no soporta el elemento de video.
                        </video>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PROGRAM INFO SECTION -->
    <section class="section program-info" id="programa">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Nuestra Propuesta</p>
                <h2 class="section-title">
                    Técnicatura Superior en Desarrollo de Software
                </h2>
                <p class="section-description">
                    Una formación sólida y abarcativa que te prepara para una industria
                    en constante expansión
                </p>
            </div>

            <div class="text-center reveal" style="margin-top: 2rem;">
                <a href="/sabermas" class="btn btn-primary btn-lg">
                    <i class="fas fa-info-circle"></i> Saber más
                </a>
            </div>
        </div>
    </section>


    <!-- CURRICULUM SECTION (DYNAMIC) -->
    <section class="section curriculum" id="curriculum">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Plan de Estudios</h2>
                <p class="section-description">
                    Actualizado anualmente con las últimas tendencias en desarrollo
                    de software e inteligencia artificial.
                </p>
            </div>

            <div class="curriculum-accordion reveal">
                <% [1, 2, 3].forEach(function(year) { %>
                    <div class="accordion-item">
                        <div class="accordion-header">
                            <h3 class="accordion-title">
                                <%= year %>° Año
                            </h3>
                            <span class="accordion-icon">▼</span>
                        </div>
                        <div class="accordion-content">
                            <div class="accordion-body">
                                <ul class="course-list">
                                    <% (curriculum[year] || []).forEach(function(subject) { %>
                                        <li>
                                            <%= subject.subject_name %>
                                        </li>
                                        <% }); %>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <% }); %>
            </div>
        </div>
    </section>


    <!-- SERVICIOS TECNOLÓGICOS INTEGRALES INCUYO -->
    <section class="section servicios-incuyo" id="servicios">
        <div class="container">
            <div class="servicios-incuyo__inner reveal">
                <p class="section-subtitle" style="color: var(--white)">
                    Nuestros servicios
                </p>

                <h2 class="servicios-incuyo__title">Servicios tecnológicos integrales</h2>

                <p class="servicios-incuyo__lead">
                    Nos especializamos en acompañar a empresas medianas en su
                    transformación digital, ofreciendo soluciones a medida, con procesos
                    claros, entregas en tiempo y soporte continuo post-implementación.
                </p>

                <a href="/servicios" class="btn btn-gold btn-lg servicios-incuyo__cta">
                    <i class="fas fa-arrow-right"></i> Conoce nuestros servicios
                </a>
            </div>
        </div>
    </section>


    <!-- DIPLOMATURAS SECTION -->
    <section class="section diplomaturas-section" id="diplomaturas">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Formación Continua</p>
                <h2 class="section-title">Diplomaturas y Cursos</h2>
                <p class="section-description">
                    Ampliá tus conocimientos con nuestras diplomaturas y cursos especializados en tecnología e
                    inteligencia artificial.
                </p>
            </div>

            <% if (diplomaturas.length===0) { %>
                <div class="diplom-empty-index">
                    <i class="fas fa-graduation-cap"></i>
                    <p>Próximamente publicaremos nuestras diplomaturas y cursos.</p>
                </div>
                <% } else { %>
                    <div class="diplom-index-grid reveal">
                        <% diplomaturas.forEach(function(d, idx) { %>
                            <article class="diplom-index-card" onclick="openIndexDiplomModal(<%= idx %>)">
                                <% if (d.imagen_url) { %>
                                    <div class="diplom-index-card__img">
                                        <img src="<%= d.imagen_url %>" alt="<%= d.nombre %>" loading="lazy" />
                                    </div>
                                    <% } else { %>
                                        <div class="diplom-index-card__img diplom-index-card__img--placeholder">
                                            <i class="fas fa-graduation-cap"></i>
                                        </div>
                                        <% } %>
                                            <div class="diplom-index-card__body">
                                                <% if (d.fecha_inicio) { %>
                                                    <span class="diplom-badge-inicio">
                                                        <i class="fas fa-calendar-alt"></i> Inicio: <%= d.fecha_inicio
                                                            %>
                                                    </span>
                                                    <% } %>
                                                        <h3 class="diplom-index-card__title">
                                                            <%= d.nombre %>
                                                        </h3>
                                                        <p class="diplom-index-card__desc">
                                                            <%= d.descripcion_breve %>
                                                        </p>
                                                        <span class="diplom-ver-link"><i class="fas fa-arrow-right"></i>
                                                            Ver diplomatura</span>
                                            </div>
                            </article>
                            <% }); %>
                    </div>
                    <% } %>

                        <div class="text-center" style="margin-top: 3rem;">
                            <a href="/diplomaturas" class="btn btn-gold btn-lg">
                                <i class="fas fa-graduation-cap"></i> Ver todas las Diplomaturas
                            </a>
                        </div>
        </div>
    </section>

    <!-- MODALES DE DETALLE (index) -->
    <% diplomaturas.forEach(function(d, idx) { %>
        <div class="diplom-modal-overlay" id="idx-modal-<%= idx %>" onclick="closeIndexDiplomModal(<%= idx %>)">
            <div class="diplom-modal" onclick="event.stopPropagation()">
                <button class="diplom-modal-close" onclick="closeIndexDiplomModal(<%= idx %>)">
                    <i class="fas fa-times"></i>
                </button>
                <% if (d.imagen_url) { %>
                    <div class="diplom-modal-img">
                        <img src="<%= d.imagen_url %>" alt="<%= d.nombre %>" />
                    </div>
                    <% } %>
                        <div class="diplom-modal-body">
                            <% if (d.fecha_inicio) { %>
                                <span class="diplom-badge-inicio">
                                    <i class="fas fa-calendar-alt"></i> Inicio: <%= d.fecha_inicio %>
                                </span>
                                <% } %>
                                    <h2 class="diplom-modal-title">
                                        <%= d.nombre %>
                                    </h2>
                                    <div class="diplom-modal-desc">
                                        <%- (d.descripcion_completa || d.descripcion_breve || '' ).replace(/\n/g, '<br>'
                                            ) %>
                                    </div>
                                    <a href="https://wa.me/5492616271658?text=<%= encodeURIComponent(d.whatsapp_msg || 'Hola! Me interesa la diplomatura: ' + d.nombre) %>"
                                        class="btn btn-whatsapp btn-lg" target="_blank">
                                        <i class="fab fa-whatsapp"></i> Consultar por WhatsApp
                                    </a>
                        </div>
            </div>
        </div>
        <% }); %>

            <!-- PASANTÍAS SECTION -->
            <% if (pasantias.length> 0) { %>
                <section class="section pasantias-section" id="pasantias">
                    <div class="container">
                        <div class="section-header">
                            <p class="section-subtitle">Vinculación Laboral</p>
                            <h2 class="section-title">Empresas con las que hemos trabajado</h2>
                            <p class="section-description">
                                Nuestros alumnos desarrollan experiencia real en empresas líderes a través de pasantías
                                y proyectos profesionales.
                            </p>
                        </div>
                    </div>
                    <!-- Carrusel igual que tech-carousel: mask-image + triple set para cubrir 1920px -->
                    <div class="pasantias-carousel-outer">
                        <div class="pasantias-carousel-track">
                            <% /* Set 1 */%>
                                <% pasantias.forEach(function(empresa) { %>
                                    <div class="pasantia-logo-item">
                                        <% if (empresa.logo_url) { %>
                                            <img src="<%= empresa.logo_url %>" alt="<%= empresa.nombre %>"
                                                title="<%= empresa.nombre %>" loading="lazy" />
                                            <% } else { %>
                                                <span class="pasantia-logo-text">
                                                    <%= empresa.nombre %>
                                                </span>
                                                <% } %>
                                    </div>
                                    <% }); %>
                                        <% /* Set 2 (copia) */%>
                                            <% pasantias.forEach(function(empresa) { %>
                                                <div class="pasantia-logo-item">
                                                    <% if (empresa.logo_url) { %>
                                                        <img src="<%= empresa.logo_url %>" alt="<%= empresa.nombre %>"
                                                            title="<%= empresa.nombre %>" loading="lazy" />
                                                        <% } else { %>
                                                            <span class="pasantia-logo-text">
                                                                <%= empresa.nombre %>
                                                            </span>
                                                            <% } %>
                                                </div>
                                                <% }); %>
                                                    <% /* Set 3 (copia) */%>
                                                        <% pasantias.forEach(function(empresa) { %>
                                                            <div class="pasantia-logo-item">
                                                                <% if (empresa.logo_url) { %>
                                                                    <img src="<%= empresa.logo_url %>"
                                                                        alt="<%= empresa.nombre %>"
                                                                        title="<%= empresa.nombre %>" loading="lazy" />
                                                                    <% } else { %>
                                                                        <span class="pasantia-logo-text">
                                                                            <%= empresa.nombre %>
                                                                        </span>
                                                                        <% } %>
                                                            </div>
                                                            <% }); %>
                        </div>
                    </div>
                </section>
                <% } %>

                    <!-- CERTIFICATIONS SECTION -->
                    <section class="section certifications" id="certificaciones">
                        <div class="container">
                            <div class="section-header">
                                <p class="section-subtitle">Valor Agregado</p>
                                <h2 class="section-title">Certificaciones Laborales Adicionales</h2>
                                <p class="section-description">
                                    La institución brinda certificaciones laborales adicionales por año
                                    al aprobar coprogramáticas.
                                </p>
                            </div>

                            <div class="cert-year-grid">
                                <% [1, 2, 3].forEach(function(year) { %>
                                    <% if (certificaciones[year] && certificaciones[year].length > 0) { %>
                                        <div class="cert-year-card reveal">
                                            <h3 class="cert-year"><%= year %>° Año</h3>
                                            <ul class="cert-list">
                                                <% certificaciones[year].forEach(function(cert) { %>
                                                    <li><%= cert.nombre %></li>
                                                <% }); %>
                                            </ul>
                                        </div>
                                    <% } %>
                                <% }); %>
                            </div>
                        </div>
                    </section>

                    <!-- STUDENT PROJECTS SECTION -->
                    <section class="section section-dark" id="proyectos">
                        <div class="container">
                            <div class="section-header">
                                <p class="section-subtitle" style="color: var(--primary-cyan)">
                                    Proyectos Reales
                                </p>
                                <h2 class="section-title">Creando desde el Primer Año</h2>
                                <p class="section-description">
                                    "Nuestros alumnos son capaces desde el primer año de crear sistemas
                                    personalizados de acuerdo a las necesidades de la actualidad".
                                </p>
                            </div>

                            <div class="text-center reveal" style="margin-top: 3rem">
                                <!-- Tech Stack Infinite Carousel -->
                                <div class="tech-carousel-container">
                                    <div class="tech-carousel">
                                        <div class="tech-carousel-track">
                                            <div class="tech-icon"><i class="fab fa-python"></i></div>
                                            <div class="tech-icon"><i class="fab fa-js"></i></div>
                                            <div class="tech-icon"><i class="fab fa-react"></i></div>
                                            <div class="tech-icon"><i class="fab fa-node"></i></div>
                                            <div class="tech-icon"><i class="fab fa-html5"></i></div>
                                            <div class="tech-icon"><i class="fab fa-css3-alt"></i></div>
                                            <div class="tech-icon"><i class="fab fa-java"></i></div>
                                            <div class="tech-icon"><i class="fab fa-php"></i></div>
                                            <div class="tech-icon"><i class="fab fa-angular"></i></div>
                                            <div class="tech-icon"><i class="fab fa-vuejs"></i></div>
                                            <div class="tech-icon"><i class="fab fa-docker"></i></div>
                                            <div class="tech-icon"><i class="fab fa-git-alt"></i></div>
                                            <!-- Duplicate set for seamless loop -->
                                            <div class="tech-icon"><i class="fab fa-python"></i></div>
                                            <div class="tech-icon"><i class="fab fa-js"></i></div>
                                            <div class="tech-icon"><i class="fab fa-react"></i></div>
                                            <div class="tech-icon"><i class="fab fa-node"></i></div>
                                            <div class="tech-icon"><i class="fab fa-html5"></i></div>
                                            <div class="tech-icon"><i class="fab fa-css3-alt"></i></div>
                                            <div class="tech-icon"><i class="fab fa-java"></i></div>
                                            <div class="tech-icon"><i class="fab fa-php"></i></div>
                                            <div class="tech-icon"><i class="fab fa-angular"></i></div>
                                            <div class="tech-icon"><i class="fab fa-vuejs"></i></div>
                                            <div class="tech-icon"><i class="fab fa-docker"></i></div>
                                            <div class="tech-icon"><i class="fab fa-git-alt"></i></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- SOCIAL COMMITMENT SECTION (DYNAMIC) -->
                    <section class="section social-commitment" id="compromiso">
                        <div class="container">
                            <div class="section-header">
                                <p class="section-subtitle">Compromiso Social</p>
                                <h2 class="section-title">Ayudando a la Comunidad</h2>
                                <p class="section-description">
                                    Los alumnos del instituto en la materia Ética organizan tareas
                                    extracurriculares para ayudar a los más necesitados.
                                </p>
                            </div>

                            <div class="image-gallery">
                                <% commitments.forEach(function(item) { // Extraer ID de la URL vieja si existe let
                                    finalUrl=item.image_url; if (finalUrl &&
                                    finalUrl.includes('/api/v1/storage/files/')) { const
                                    fileId=finalUrl.split('/api/v1/storage/files/')[1].split('?')[0];
                                    finalUrl=`/api/storage/files/${fileId}`; } %>
                                    <div class="gallery-item reveal">
                                        <img src="<%= finalUrl %>" alt="<%= item.title %>" loading="lazy" />
                                        <div class="gallery-item-overlay">
                                            <p class="gallery-item-title">
                                                <%= item.title %>
                                            </p>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                        </div>
                    </section>

                    <!-- ENROLLMENT SECTION -->
                    <section class="section section-dark enrollment" id="inscripciones">
                        <div class="container">
                            <div class="section-header">
                                <p class="section-subtitle" style="color: var(--primary-gold)">
                                    ¡No te quedes afuera!
                                </p>
                                <h2 class="section-title">Inscripciones Abiertas desde Agosto</h2>
                            </div>

                            <div class="highlight-box reveal">
                                <div class="text-center">
                                    <div class="scholarship-badge">
                                        <i class="fas fa-graduation-cap"></i> BECAS CON HASTA 40% DE DESCUENTO
                                    </div>
                                    <p style="color: white; font-size: 1.125rem; margin-bottom: 2rem">
                                        ¡Consultá por precios y promociones especiales!
                                    </p>
                                </div>

                                <div class="highlight-grid">
                                    <div class="highlight-item reveal">
                                        <div class="highlight-item-icon"><i class="fas fa-laptop-code"></i></div>
                                        <p class="highlight-item-text">
                                            Creá y diseñá aplicaciones para todo tipo de dispositivo
                                        </p>
                                    </div>

                                    <div class="highlight-item reveal">
                                        <div class="highlight-item-icon"><i class="fas fa-rocket"></i></div>
                                        <p class="highlight-item-text">
                                            Desarrollá aplicaciones con las últimas tecnologías
                                        </p>
                                    </div>

                                    <div class="highlight-item reveal">
                                        <div class="highlight-item-icon"><i class="fas fa-robot"></i></div>
                                        <p class="highlight-item-text">
                                            Aprendé con Inteligencia Artificial integrada en las materias
                                        </p>
                                    </div>
                                </div>

                                <div class="text-center" style="margin-top: 2rem">
                                    <a href="https://wa.me/5492616271658?text=Hola!%20Me%20interesa%20información%20sobre%20la%20Tecnicatura%20en%20Desarrollo%20de%20Software"
                                        class="btn btn-primary btn-lg" target="_blank">
                                        <i class="fab fa-whatsapp"></i> Consultá por Inscripciones
                                    </a>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- LOCATION SECTION -->
                    <section class="section location" id="ubicacion">
                        <div class="container">
                            <div class="section-header">
                                <p class="section-subtitle">Visitanos</p>
                                <h2 class="section-title">Nuestra Ubicación</h2>
                                <p class="section-description">
                                    <i class="fas fa-map-marker-alt"></i> La Rioja 614 - Ciudad de
                                    Mendoza - Argentina
                                </p>

                                <!-- HORARIO -->
                                <div class="horario-widget reveal" style="margin-bottom: 1.5rem;">
                                    <div class="horario-widget__header">
                                        <i class="fas fa-user-clock"></i>
                                        <span>Atención al público</span>
                                    </div>
                                    <div class="horario-grid">
                                        <div class="horario-row">
                                            <span class="horario-dia">Lunes a Viernes</span>
                                            <span class="horario-hs">
                                                <i class="fas fa-circle horario-dot horario-dot--open"></i> 16:00 – 20:00
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <% if (horario && horario.length> 0) { %>
                                    <div class="horario-widget reveal">
                                        <div class="horario-widget__header">
                                            <i class="fas fa-clock"></i>
                                            <span>Horario de Atención</span>
                                        </div>
                                        <div class="horario-grid">
                                            <% horario.forEach(function(dia) { %>
                                                <div
                                                    class="horario-row <%= dia.abierto ? '' : 'horario-row--cerrado' %>">
                                                    <span class="horario-dia">
                                                        <%= dia.dia %>
                                                    </span>
                                                    <span class="horario-hs">
                                                        <% if (dia.abierto) { %>
                                                            <i class="fas fa-circle horario-dot horario-dot--open"></i>
                                                            <%= dia.apertura %> – <%= dia.cierre %>
                                                                    <% } else { %>
                                                                        <i
                                                                            class="fas fa-circle horario-dot horario-dot--closed"></i>
                                                                        Cerrado
                                                                        <% } %>
                                                    </span>
                                                </div>
                                                <% }); %>
