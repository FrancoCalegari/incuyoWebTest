<!doctype html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description"
        content="Conocé en detalle la Tecnicatura Superior en Desarrollo de Software del Instituto INCUYO: plan de estudios, materias, títulos, certificaciones laborales, modalidad e ingreso." />
    <title>Más Info sobre la Carrera · INCUYO</title>

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/masinfo.css">
</head>

<body>
    <!-- NAVIGATION -->
    <nav class="navbar" id="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <img src="/assets/img/logo.png" alt="Instituto Nuevo Cuyo" class="navbar-logo" />
            </a>

            <button class="navbar-toggle" id="navbarToggle" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <ul class="navbar-menu" id="navbarMenu">
                <li><a href="/" class="btn btn-secondary-no-bg" style="padding: 0.5rem 1rem; border-radius: 4px; font-weight: 600;"><i class="fas fa-arrow-left" style="margin-right: 5px;"></i> Volver al Inicio</a></li>
            </ul>
        </div>
    </nav>

    <!-- HERO -->
    <section class="mi-hero">
        <div class="container" style="position:relative; z-index:2;">
            <p class="mi-hero-eyebrow">Tecnicatura Superior en Desarrollo de Software DGE/R:6079</p>
            <h1>Todo lo que necesitás saber<br>sobre la carrera</h1>
            <p>3 años · Bimodal · IA integrada · Títulos intermedios habilitantes · Certificaciones laborales</p>

            <div class="mi-chips">
                <span class="mi-chip"><i class="fas fa-calendar-alt"></i> 3 Años (6 cuatrimestres)</span>
                <span class="mi-chip"><i class="fas fa-laptop"></i> Modalidad Bimodal</span>
                <span class="mi-chip"><i class="fas fa-robot"></i> IA en todas las materias</span>
                <span class="mi-chip"><i class="fas fa-certificate"></i> 3 Títulos oficiales</span>
                <span class="mi-chip"><i class="fas fa-award"></i> Certificaciones laborales</span>
                <% if (becaVisible) { %>
                <span class="mi-chip"><i class="fas fa-graduation-cap"></i> Becas hasta 40% En Agosto</span>
                <% } %>
            </div>
        </div>
    </section>

    <!-- TÍTULOS INTERMEDIOS -->
    <section class="section" style="background: var(--gray-100);">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle"><%= config.titulos_subtitle || 'Al finalizar cada año' %></p>
                <h2 class="section-title"><%= config.titulos_title || 'Los títulos que obtenés' %></h2>
                <p class="section-description">
                    <%= config.titulos_desc || 'Títulos intermedios desde 2do año, 3ro título final más 8 certificaciones laborales desde primer año.' %>
                </p>
            </div>

            <div class="years-banner">
                <!--
                <div class="year-item">
                    <div class="year-badge">1</div>
                    <p class="year-title-degree">Al terminar 1° Año</p>
                    <p class="year-degree">Programador Junior</p>
                </div>
                -->
                <div class="year-item">
                    <div class="year-badge">2</div>
                    <p class="year-title-degree"><%= config.titulos_2_title || 'Al terminar 2° Año' %></p>
                    <p class="year-degree"><%= config.titulos_2_desc || 'Desarrollador full Stack' %></p>
                </div>
                <div class="year-item">
                    <div class="year-badge">3</div>
                    <p class="year-title-degree"><%= config.titulos_3_title || 'Al terminar 3° Año' %></p>
                    <p class="year-degree"><%= config.titulos_3_desc || 'Técnico Superior en Desarrollo de Software + IA' %></p>
                </div>
            </div>

            <!-- Resolución -->
            <div class="card text-center" style="max-width:520px; margin: 0 auto;">
                <p style="color: var(--gray-600); margin: 0;">
                    <i class="fas fa-file-alt" style="color:var(--primary-gold);"></i>
                    Carrera oficial nacional reconocida por la Resolución<br>
                    <strong style="color:var(--gray-900);"><%= config.titulos_resolucion || 'DGE/R:6079' %></strong>
                </p>
            </div>
        </div>
    </section>

    <!-- PLAN DE ESTUDIOS -->
    <section class="section">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle"><%= config.plan_subtitle || 'Plan de Estudios' %></p>
                <h2 class="section-title" style="color:#10182c"><%= config.plan_title || 'Materias por año' %></h2>
                <p class="section-description">
                    <%= config.plan_desc || 'Plan actualizado con las últimas tendencias en desarrollo de software e inteligencia artificial' %>
                </p>
            </div>

            <div class="curriculum-tabs">
                <button class="curr-tab active" data-tab="year1">1° Año</button>
                <button class="curr-tab" data-tab="year2">2° Año</button>
                <button class="curr-tab" data-tab="year3">3° Año</button>
            </div>

            <% [1, 2, 3].forEach(function(year) { %>
                <!-- <%= year %>° Año -->
                <div class="curr-panel <%= year === 1 ? 'active' : '' %>" id="year<%= year %>">
                    <div class="subject-grid">
                        <% (curriculum[year] || []).forEach(function(subject) { %>
                            <div class="subject-card">
                                <div class="subject-icon"><i class="fas fa-book"></i></div>
                                <p class="subject-name">
                                    <%= subject.subject_name %>
                                </p>
                                <% if (subject.semestre) { %>
                                    <p class="subject-semestre"
                                        style="font-size:0.75rem; margin-top:0.3rem; color:#a0a9c0; letter-spacing:0.02em;">
                                        <% if (subject.semestre==='anual' ) { %>Anual<% } else { %>
                                                <%= subject.semestre %>° Semestre<% } %>
                                    </p>
                                    <% } %>
                            </div>
                            <% }); %>
                    </div>
                </div>
                <% }); %>
        </div>
    </section>

    <!-- CERTIFICACIONES LABORALES -->
    <section class="section" style="background: var(--gray-100);">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle"><%= config.cert_subtitle || 'Valor Adicional' %></p>
                <h2 class="section-title" style="color:#10182c"><%= config.cert_title || 'Certificaciones Laborales' %></h2>
                <p class="section-description">
                    <%= config.cert_desc || 'Al aprobar materias coprogramáticas, obtenés certificaciones reconocidas por la industria' %>
                </p>
            </div>

            <div class="cert-grid">
                <div class="cert-card">
                    <div class="cert-card-header">
                        <span class="year-num">1°</span>
                        <span class="year-label">Año</span>
                    </div>
                    <div class="cert-card-body">
                        <div class="cert-item"><i class="fas fa-desktop"></i> Técnico en Hardware y Software</div>
                        <div class="cert-item"><i class="fab fa-python"></i> Programador Python (nivel Junior)</div>
                    </div>
                </div>

                <div class="cert-card">
                    <div class="cert-card-header">
                        <span class="year-num">2°</span>
                        <span class="year-label">Año</span>
                    </div>
                    <div class="cert-card-body">
                        <div class="cert-item"><i class="fab fa-linux"></i> Sistemas Operativos (Linux-Windows)</div>
                        <div class="cert-item"><i class="fas fa-building"></i> Sistemas de Programación Pymes</div>
                        <div class="cert-item"><i class="fas fa-project-diagram"></i> Análisis y Técnicas de Sistemas</div>
                        <div class="cert-item"><i class="fas fa-cloud"></i> Inteligencia Artificial en la Nube</div>
                    </div>
                </div>

                <div class="cert-card">
                    <div class="cert-card-header">
                        <span class="year-num">3°</span>
                        <span class="year-label">Año</span>
                    </div>
                    <div class="cert-card-body">
                        <div class="cert-item"><i class="fas fa-paint-brush"></i> Diseño y Programación de Páginas Web
                        </div>
                        <div class="cert-item"><i class="fas fa-database"></i> WEB SITE con Bases de Datos Dinámicas
                        </div>
                        <div class="cert-item"><i class="fas fa-robot"></i> Experto en Inteligencia Artificial Senior</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MODALIDAD -->
    <section class="section">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Cómo cursás</p>
                <h2 class="section-title" style="color:#10182c">Modalidad Bimodal</h2>
            </div>

            <div class="modality-split">
                <div class="modality-image-block">
                    <i class="fas fa-laptop-code"></i>
                </div>
                <div>
                    <h3 style="color: var(--gray-900); margin-bottom: var(--space-4);">
                        Presencial o por Zoom
                    </h3>
                    <p style="color: var(--gray-600); font-size: var(--text-lg);">
                        Cursado <strong>Bimodal</strong> y ágil, para alumnos con otras ocupaciones.
                    </p>
                    <ul class="modality-features">
                        <li><i class="fas fa-check-circle"></i> Asistí presencial en La Rioja 614, Mendoza</li>
                        <li><i class="fas fa-video"></i> Conectate por Zoom en tiempo real desde cualquier lugar</li>
                        <li><i class="fas fa-play-circle"></i> Todas las clases quedan grabadas para consultar cuando
                            quieras</li>
                        <li><i class="fas fa-robot"></i> Inteligencia Artificial integrada en todas las materias</li>
                        <li><i class="fas fa-chalkboard-teacher"></i> Docentes con experiencia real en la industria</li>
                        <li><i class="fas fa-users"></i> Proyectos reales desde el primer año</li>
                        <li><i class="fas fa-clock"></i> 3 clases Bimodal y 2 clases asíncronicas semanales</li>
                        <li><i class="fas fa-computer"></i> Prácticas en laboratorio desde la primer semana hasta la última</li>
                        <li><i class="fas fa-flag"></i> Garantía de aprendizaje (1 Clase semanal de apoyo)</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- CONDICIONES DE INGRESO -->
    <section class="section" style="background: var(--gray-100);">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">¿Quién puede anotarse?</p>
                <h2 class="section-title" style="color:#10182c">Condiciones de Ingreso</h2>
            </div>

            <div class="ingreso-box">
                <div class="ingreso-icon-wrap">
                    <i class="fas fa-door-open"></i>
                </div>
                <div class="ingreso-content">
                    <h2>Acceso amplio e inclusivo</h2>
                    <p><i class="fas fa-check" style="color:var(--primary-gold); margin-right:.5rem;"></i>
                        Haber aprobado el nivel Secundario o estar cursando el último año.</p>
                    <p><i class="fas fa-check" style="color:var(--primary-gold); margin-right:.5rem;"></i>
                        Ser mayor de <strong>25 años</strong> sin secundario completo (Art. 7° de la Ley de Educación
                        Superior N° 24.521).</p>
                    <p style="margin-top:var(--space-4); color:rgba(255,255,255,.7); font-size:var(--text-sm);">
                        <i class="fas fa-calendar-check"></i>&nbsp;
                        Inscripciones abiertas desde agosto de cada año. Podés pre-inscribirte en cualquier momento.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="final-cta">
        <div class="container">
            <h2>¿Listo para empezar tu futuro?</h2>
            <p>Consultá por inscripciones, becas y toda la información que necesitás para dar el primer paso</p>
            <div class="final-cta-btns">
                <% if (becaVisible) { %>
                <button class="btn btn-gold btn-lg" onclick="openBecaModal()"
                    style="font-size: 1.1rem; padding: 1rem 2.5rem;">
                    <i class="fas fa-envelope-open-text"></i> Solicitar Beca Ahora
                </button>
                <% } %>
                <a href="/" class="btn btn-secondary btn-lg">
                    <i class="fas fa-arrow-left"></i> Volver al Inicio
                </a>
            </div>
        </div>
    </section>

    <!-- BECA MODAL -->
    <% if (becaVisible) { %>
    <div class="diplom-modal-overlay" id="publicBecaModal" style="z-index: 10000;" onclick="closeBecaModal()">
        <div class="diplom-modal" onclick="event.stopPropagation()" style="max-width: 650px; background: #fff; padding: 2rem; border-radius: 12px;">
            <button class="diplom-modal-close" onclick="closeBecaModal()">
                <i class="fas fa-times"></i>
            </button>

            <h2 style="color: #10182c; margin-bottom: 1.5rem; text-align: center; font-size: 1.8rem;">
                <i class="fas fa-graduation-cap" style="color: var(--primary-gold);"></i> Solicitud de Beca 2027
            </h2>

            <form id="becaForm" onsubmit="submitBeca(event)">
                <!-- Sección 1: Información Personal -->
                <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #e2e8f0;">
                    <h3 style="color: #334155; font-size: 1.1rem; margin-bottom: 1rem;"><i class="fas fa-user"></i> 1. Información Personal</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                        <div>
                            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Nombre *</label>
                            <input type="text" id="becaInputFirstName" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="Tu nombre">
                        </div>
                        <div>
                            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Apellido *</label>
                            <input type="text" id="becaInputLastName" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="Tu apellido">
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div>
                            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Edad *</label>
                            <input type="number" id="becaInputAge" required min="17" max="99" style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="Tu edad" oninput="checkArticulo7()">
                        </div>
                        <div>
                            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">¿Terminó la secundaria? *</label>
                            <select id="becaInputHS" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px; background: white;" onchange="checkArticulo7()">
                                <option value="" disabled selected>Seleccione</option>
                                <option value="1">Sí</option>
                                <option value="0">No</option>
                            </select>
                        </div>
                    </div>
                    <div id="articulo7Alert" style="display: none; margin-top: 1rem; padding: 0.75rem; background-color: #fef9c3; border-left: 4px solid #eab308; color: #854d0e; font-size: 0.9rem; border-radius: 4px;">
                        <i class="fas fa-info-circle"></i> <strong>Aviso:</strong> Como indicaste que no has terminado la secundaria, tu edad mínima para inscribirte debe ser de 25 años en adelante (Ingreso amparado por el Artículo 7mo de la Ley de Educación Superior).
                    </div>
                </div>

                <!-- Sección 2: Preferencia y Motivo -->
                <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #e2e8f0;">
                    <h3 style="color: #334155; font-size: 1.1rem; margin-bottom: 1rem;"><i class="fas fa-pen"></i> 2. Preferencia de Horario y Motivo</h3>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem; color: #64748b;">Turnos de preferencia (Mínimo 1, Máximo 2) *</label>
                    <div style="display: flex; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; color: #334155; cursor: pointer;">
                            <input type="checkbox" class="becaShiftCb" value="Mañana" onchange="checkShifts()"> Mañana
                        </label>
                        <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; color: #334155; cursor: pointer;">
                            <input type="checkbox" class="becaShiftCb" value="Tarde" onchange="checkShifts()"> Tarde
                        </label>
                        <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; color: #334155; cursor: pointer;">
                            <input type="checkbox" class="becaShiftCb" value="Vespertino" onchange="checkShifts()"> Vespertino
                        </label>
                    </div>
                    <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">¿Por qué solicitás la beca? *</label>
                    <textarea id="becaInputReason" required rows="3" style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px; resize: vertical;" placeholder="Contanos brevemente tu situación..."></textarea>
                </div>

                <!-- Sección 3: Contacto -->
                <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #e2e8f0;">
                    <h3 style="color: #334155; font-size: 1.1rem; margin-bottom: 1rem;"><i class="fas fa-address-book"></i> 3. Información de Contacto</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div>
                            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Correo Electrónico *</label>
                            <input type="email" id="becaInputEmail" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="ejemplo@correo.com">
                        </div>
                        <div>
                            <label style="display: block; margin-bottom: 0.3rem; font-size: 0.9rem; color: #64748b;">Celular / WhatsApp *</label>
                            <input type="tel" id="becaInputPhone" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 6px;" placeholder="+54 9 ...">
                        </div>
                    </div>
                </div>

                <div style="text-align: center;">
                    <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 1rem;">Un asesor te responderá dentro de las 72 horas hábiles.</p>
                    <button type="submit" id="becaSubmitBtn" class="btn btn-gold btn-lg" style="width: 100%;">
                        Enviar Solicitud de Beca
                    </button>
                </div>
            </form>
        </div>
    </div>
    <% } %>

    <!-- Toast notification -->
    <div id="customToast" style="visibility: hidden; min-width: 250px; background-color: #333; color: #fff; text-align: center; border-radius: 4px; padding: 16px; position: fixed; z-index: 10001; left: 50%; bottom: 30px; transform: translateX(-50%); box-shadow: 0 4px 6px rgba(0,0,0,0.1); font-size: 1rem; opacity: 0; transition: opacity 0.5s, bottom 0.5s;">
        <span id="customToastMessage">Mensaje</span>
    </div>

    <!-- FOOTER mínimo -->
    <footer
        style="background: var(--gradient-dark); color: rgba(255,255,255,.6); text-align:center; padding: var(--space-6);">
        <p style="margin:0; color: rgba(255,255,255,.5); font-size:var(--text-sm);">
            © 2026 Instituto Nuevo Cuyo · La Rioja 614, Mendoza ·
            <a href="tel:+5492616271658" style="color:var(--primary-gold);">+54 9 261 627-1658</a>
        </p>
    </footer>

    <!-- WhatsApp + AI Chat Flotante -->
    <div class="whatsapp-float">
        <!-- AI CHATBOT BUTTON (Desactivado en esta sección) -->
        <!--
        <button class="ai-chat-btn" id="aiChatBtn" aria-label="Hablar con el Asistente IA" title="Asistente INCUYO IA">
