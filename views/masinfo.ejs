    <!-- Script compartido (incluye lógica del chatbot) -->
    <script src="/js/script.js"></script>

    <script>
        // Tab switching for curriculum
        const tabs = document.querySelectorAll('.curr-tab');
        const panels = document.querySelectorAll('.curr-panel');
        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                panels.forEach(p => p.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById(tab.dataset.tab).classList.add('active');
            });
        });

        // ─── BECA MODAL LOGIC ───────────────────────────────
        function openBecaModal() {
            document.getElementById('publicBecaModal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeBecaModal() {
            document.getElementById('publicBecaModal').classList.remove('active');
            document.body.style.overflow = '';
            document.getElementById('becaForm').reset();
            document.getElementById('articulo7Alert').style.display = 'none';
        }

        function checkArticulo7() {
            const ageInput = document.getElementById('becaInputAge');
            const hs = document.getElementById('becaInputHS').value;
            const alertBox = document.getElementById('articulo7Alert');
            if (hs === '0') {
                ageInput.min = "25";
                alertBox.style.display = 'block';
            } else {
                ageInput.min = "17";
                alertBox.style.display = 'none';
            }
        }

        function checkShifts() {
            const cbs = document.querySelectorAll('.becaShiftCb');
            let checkedCount = 0;
            cbs.forEach(cb => { if (cb.checked) checkedCount++; });
            cbs.forEach(cb => {
                if (!cb.checked) cb.disabled = checkedCount >= 2;
            });
        }

        async function submitBeca(e) {
            e.preventDefault();
            const checkedShifts = Array.from(document.querySelectorAll('.becaShiftCb'))
                .filter(cb => cb.checked)
                .map(cb => cb.value);
            if (checkedShifts.length === 0) {
                showToast("Por favor seleccione al menos un turno de preferencia.", true);
                return;
            }
            const btn = document.getElementById('becaSubmitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
            const payload = {
                first_name: document.getElementById('becaInputFirstName').value.trim(),
                last_name: document.getElementById('becaInputLastName').value.trim(),
                reason: document.getElementById('becaInputReason').value.trim(),
                email: document.getElementById('becaInputEmail').value.trim(),
                phone: document.getElementById('becaInputPhone').value.trim(),
                age: parseInt(document.getElementById('becaInputAge').value, 10),
                high_school_finished: document.getElementById('becaInputHS').value === '1',
                preferred_shifts: checkedShifts.join(', ')
            };
            try {
                const res = await fetch('/api/scholarships', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if (data.ok) {
                    showToast('¡Solicitud enviada con éxito! Te responderemos pronto.');
                    closeBecaModal();
                } else {
                    showToast('Error al enviar solicitud: ' + (data.error || 'Desconocido'), true);
                }
            } catch (err) {
                showToast('Error de conexión. Intente nuevamente.', true);
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Enviar Solicitud de Beca';
            }
        }

        function showToast(message, isError = false) {
            const toast = document.getElementById('customToast');
            const toastMessage = document.getElementById('customToastMessage');
            toastMessage.textContent = message;
            toast.style.backgroundColor = isError ? '#ef4444' : '#22c55e';
            toast.style.visibility = 'visible';
            toast.style.opacity = '1';
            toast.style.bottom = '50px';
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.bottom = '30px';
                setTimeout(() => { toast.style.visibility = 'hidden'; }, 500);
            }, 3000);
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                const modal = document.getElementById('publicBecaModal');
                if (modal && modal.classList.contains('active')) closeBecaModal();
            }
        });
    </script>
</body>

</html>