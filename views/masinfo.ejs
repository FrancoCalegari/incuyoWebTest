<!doctype html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description"
        content="Conocé en detalle la Tecnicatura Superior en Desarrollo de Software del Instituto INCUYO: plan de estudios, materias, títulos, certificaciones laborales, modalidad e ingreso." />
    <title>Más Info sobre la Carrera · INCUYO</title>

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/masinfo.css">
</head>

<body>
    <!-- NAVBAR -->
    <nav class="navbar scrolled" id="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <img src="/assets/img/logo.png" alt="Instituto Nuevo Cuyo" class="navbar-logo" />
            </a>
            <ul class="navbar-menu">
                <li><a href="/">Inicio</a></li>
                <li><a href="/#inscripciones">Inscripciones</a></li>
                <li><a href="/proyectosalumnos">Proyectos</a></li>
                <li>
                    <a href="https://aula.incuyo.edu.ar/" target="_blank" class="campus-link">Campus Virtual</a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- HERO -->
    <section class="mi-hero">
        <div class="container" style="position:relative; z-index:2;">
            <p class="mi-hero-eyebrow">Tecnicatura Superior en Desarrollo de Software</p>
            <h1>Todo lo que necesitás saber<br>sobre la carrera</h1>
            <p>3 años · Bimodal · IA integrada · Títulos intermedios habiliantes · Certificaciones laborales</p>

            <div class="mi-chips">
                <span class="mi-chip"><i class="fas fa-calendar-alt"></i> 3 Años (6 cuatrimestres)</span>
                <span class="mi-chip"><i class="fas fa-laptop"></i> Modalidad Bimodal</span>
                <span class="mi-chip"><i class="fas fa-robot"></i> IA en todas las materias</span>
                <span class="mi-chip"><i class="fas fa-certificate"></i> 2 Títulos oficiales</span>
                <span class="mi-chip"><i class="fas fa-award"></i> Certificaciones laborales</span>
                <span class="mi-chip"><i class="fas fa-graduation-cap"></i> Becas hasta 40%</span>
            </div>
        </div>
    </section>

    <!-- TÍTULOS INTERMEDIOS -->
    <section class="section" style="background: var(--gray-100);">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Al finalizar cada año</p>
                <h2 class="section-title">Los títulos que obtenés</h2>
                <p class="section-description">
                    Títulos intermedios desde 2do año, 3ro título final más 8 certificaciones laborales desde primer
                    año.
                </p>
            </div>

            <div class="years-banner">
                <!--
                <div class="year-item">
                    <div class="year-badge">1</div>
                    <p class="year-title-degree">Al terminar 1° Año</p>
                    <p class="year-degree">Programador Junior</p>
                </div>
                -->
                <div class="year-item">
                    <div class="year-badge">2</div>
                    <p class="year-title-degree">Al terminar 2° Año</p>
                    <p class="year-degree">Desarrollador Full Stack Junior</p>
                </div>
                <div class="year-item">
                    <div class="year-badge">3</div>
                    <p class="year-title-degree">Al terminar 3° Año</p>
                    <p class="year-degree">Técnico Superior en Desarrollo de Software</p>
                </div>
            </div>

            <!-- Resolución -->
            <div class="card text-center" style="max-width:520px; margin: 0 auto;">
                <p style="color: var(--gray-600); margin: 0;">
                    <i class="fas fa-file-alt" style="color:var(--primary-gold);"></i>
                    Carrera oficial reconocida por la Resolución<br>
                    <strong style="color:var(--gray-900);">DGE/R:6079</strong>
                </p>
            </div>
        </div>
    </section>

    <!-- PLAN DE ESTUDIOS -->
    <section class="section">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Plan de Estudios</p>
                <h2 class="section-title">Materias por año</h2>
                <p class="section-description">
                    Plan actualizado con las últimas tendencias en desarrollo de software e inteligencia artificial
                </p>
            </div>

            <div class="curriculum-tabs">
                <button class="curr-tab active" data-tab="year1">1° Año</button>
                <button class="curr-tab" data-tab="year2">2° Año</button>
                <button class="curr-tab" data-tab="year3">3° Año</button>
            </div>

            <% [1, 2, 3].forEach(function(year) { %>
                <!-- <%= year %>° Año -->
                <div class="curr-panel <%= year === 1 ? 'active' : '' %>" id="year<%= year %>">
                    <div class="subject-grid">
                        <% (curriculum[year] || []).forEach(function(subject) { %>
                            <div class="subject-card">
                                <div class="subject-icon"><i class="fas fa-book"></i></div>
                                <p class="subject-name"><%= subject.subject_name %></p>
                                <% if (subject.semestre) { %>
                                    <p class="subject-semestre" style="font-size:0.75rem; margin-top:0.3rem; color:#a0a9c0; letter-spacing:0.02em;">
                                        <% if (subject.semestre === 'anual') { %>Anual<% } else { %><%= subject.semestre %>° Semestre<% } %>
                                    </p>
                                <% } %>
                            </div>
                        <% }); %>
                    </div>
                </div>
            <% }); %>
        </div>
    </section>

    <!-- CERTIFICACIONES LABORALES -->
    <section class="section" style="background: var(--gray-100);">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Valor Adicional</p>
                <h2 class="section-title">Certificaciones Laborales</h2>
                <p class="section-description">
                    Al aprobar materias coprogramáticas, obtenés certificaciones reconocidas por la industria
                </p>
            </div>

            <div class="cert-grid">
                <div class="cert-card">
                    <div class="cert-card-header">
                        <span class="year-num">1°</span>
                        <span class="year-label">Año</span>
                    </div>
                    <div class="cert-card-body">
                        <div class="cert-item"><i class="fas fa-desktop"></i> Técnico en Hardware y Software</div>
                        <div class="cert-item"><i class="fab fa-python"></i> Programador Python (nivel Junior)</div>
                    </div>
                </div>

                <div class="cert-card">
                    <div class="cert-card-header">
                        <span class="year-num">2°</span>
                        <span class="year-label">Año</span>
                    </div>
                    <div class="cert-card-body">
                        <div class="cert-item"><i class="fab fa-linux"></i> Sistemas Operativos (Linux-Windows)</div>
                        <div class="cert-item"><i class="fas fa-building"></i> Sistemas de Programación Pymes</div>
                        <div class="cert-item"><i class="fas fa-project-diagram"></i> Análisis y Técnicas de Sistemas
                        </div>
                    </div>
                </div>

                <div class="cert-card">
                    <div class="cert-card-header">
                        <span class="year-num">3°</span>
                        <span class="year-label">Año</span>
                    </div>
                    <div class="cert-card-body">
                        <div class="cert-item"><i class="fas fa-paint-brush"></i> Diseño y Programación de Páginas Web
                        </div>
                        <div class="cert-item"><i class="fas fa-database"></i> WEB SITE con Bases de Datos Dinámicas
                        </div>
                        <div class="cert-item"><i class="fas fa-cloud"></i> Inteligencia Artificial en la Nube</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MODALIDAD -->
    <section class="section">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">Cómo cursás</p>
                <h2 class="section-title">Modalidad Bimodal</h2>
            </div>

            <div class="modality-split">
                <div class="modality-image-block">
                    <i class="fas fa-laptop-code"></i>
                </div>
                <div>
                    <h3 style="color: var(--gray-900); margin-bottom: var(--space-4);">
                        Presencial o por Zoom
                    </h3>
                    <p style="color: var(--gray-600); font-size: var(--text-lg);">
                        Cursado <strong>Bimodal</strong> y ágil, para alumnos con otras ocupaciones.
                    </p>
                    <ul class="modality-features">
                        <li><i class="fas fa-check-circle"></i> Asistí presencial en La Rioja 614, Mendoza</li>
                        <li><i class="fas fa-video"></i> Conectate por Zoom en tiempo real desde cualquier lugar</li>
                        <li><i class="fas fa-play-circle"></i> Todas las clases quedan grabadas para consultar cuando
                            quieras</li>
                        <li><i class="fas fa-robot"></i> Inteligencia Artificial integrada en todas las materias</li>
                        <li><i class="fas fa-chalkboard-teacher"></i> Docentes con experiencia real en la industria</li>
                        <li><i class="fas fa-users"></i> Proyectos reales desde el primer año</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- CONDICIONES DE INGRESO -->
    <section class="section" style="background: var(--gray-100);">
        <div class="container">
            <div class="section-header">
                <p class="section-subtitle">¿Quién puede anotarse?</p>
                <h2 class="section-title">Condiciones de Ingreso</h2>
            </div>

            <div class="ingreso-box">
                <div class="ingreso-icon-wrap">
                    <i class="fas fa-door-open"></i>
                </div>
                <div class="ingreso-content">
                    <h2>Acceso amplio e inclusivo</h2>
                    <p><i class="fas fa-check" style="color:var(--primary-gold); margin-right:.5rem;"></i>
                        Haber aprobado el nivel Secundario o Ciclo Polimodal.</p>
                    <p><i class="fas fa-check" style="color:var(--primary-gold); margin-right:.5rem;"></i>
                        Ser mayor de <strong>25 años</strong> sin secundario completo (Art. 7° de la Ley de Educación
                        Superior N° 24.521).</p>
                    <p style="margin-top:var(--space-4); color:rgba(255,255,255,.7); font-size:var(--text-sm);">
                        <i class="fas fa-calendar-check"></i>&nbsp;
                        Inscripciones abiertas desde agosto de cada año. Podés pre-inscribirte en cualquier momento.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="final-cta">
        <div class="container">
            <h2>¿Listo para empezar tu futuro?</h2>
            <p>Consultá por inscripciones, becas y toda la información que necesitás para dar el primer paso</p>
            <div class="final-cta-btns">
                <a href="https://wa.me/5492616271658?text=Hola!%20Me%20interesa%20inscribirme%20en%20la%20Tecnicatura%20en%20Desarrollo%20de%20Software"
                    class="btn btn-gold btn-lg" target="_blank">
                    <i class="fab fa-whatsapp"></i> Consultá por WhatsApp
                </a>
                <a href="/" class="btn btn-secondary btn-lg">
                    <i class="fas fa-arrow-left"></i> Volver al Inicio
                </a>
            </div>
        </div>
    </section>

    <!-- FOOTER mínimo -->
    <footer
        style="background: var(--gradient-dark); color: rgba(255,255,255,.6); text-align:center; padding: var(--space-6);">
        <p style="margin:0; color: rgba(255,255,255,.5); font-size:var(--text-sm);">
            © 2026 Instituto Nuevo Cuyo · La Rioja 614, Mendoza ·
            <a href="tel:+5492616271658" style="color:var(--primary-gold);">+54 9 261 627-1658</a>
        </p>
    </footer>

    <!-- WhatsApp + AI Chat Flotante -->
    <div class="whatsapp-float">
        <!-- AI CHATBOT BUTTON -->
        <button class="ai-chat-btn" id="aiChatBtn" aria-label="Hablar con el Asistente IA" title="Asistente INCUYO IA">
            <img src="/assets/img/robbie.png" alt="Robbie"
                style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; padding: 10px; background: white;">
        </button>

        <a href="https://wa.me/5492616271658?text=Hola!%20Me%20interesa%20información%20sobre%20la%20Tecnicatura"
            class="whatsapp-btn" target="_blank" aria-label="Contactar por WhatsApp">
            <i class="fab fa-whatsapp"></i>
        </a>
    </div>

    <!-- AI CHATBOT WINDOW -->
    <div class="ai-chat-window" id="aiChatWindow" aria-hidden="true">
        <div class="ai-chat-header">
            <div class="ai-chat-header-info">
                <div class="ai-chat-avatar">
                    <img src="/assets/img/robbie.png" alt="Robbie"
                        style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; padding: 5px; background: white;">
                </div>
                <div>
                    <p class="ai-chat-title">Asistente INCU</p>
                    <p class="ai-chat-subtitle">Respondido por IA · SpiderWeb</p>
                </div>
            </div>
            <button class="ai-chat-close" id="aiChatClose" aria-label="Cerrar chat">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="ai-chat-messages" id="aiChatMessages">
            <div class="ai-chat-msg ai-chat-msg--bot">
                <div class="ai-chat-msg-bubble">
                    <i class="fas fa-hand-sparkles" style="color: var(--primary-gold);"></i> ¡Hola! Soy el asistente
                    virtual del <strong>Instituto Nuevo Cuyo</strong>. Puedo responder preguntas
                    sobre la Tecnicatura en Desarrollo de Software, inscripciones, plan de estudios, certificaciones y
                    más. ¿En qué puedo ayudarte?
                </div>
            </div>
        </div>

        <div class="ai-chat-input-area">
            <textarea class="ai-chat-input" id="aiChatInput" placeholder="Escribí tu pregunta..." rows="1"
                maxlength="500" aria-label="Mensaje para el asistente"></textarea>
            <button class="ai-chat-send" id="aiChatSend" aria-label="Enviar mensaje">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>

    <!-- Script compartido (incluye lógica del chatbot) -->
    <script src="/js/script.js"></script>

    <script>
        // Tab switching for curriculum
        const tabs = document.querySelectorAll('.curr-tab');
        const panels = document.querySelectorAll('.curr-panel');
        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                panels.forEach(p => p.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById(tab.dataset.tab).classList.add('active');
            });
        });
    </script>
</body>

</html>