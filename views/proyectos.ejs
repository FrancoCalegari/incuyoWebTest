<!doctype html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description"
        content="Proyectos creados por alumnos del Instituto INCUYO - Tecnicatura en Desarrollo de Software" />
    <title>Proyectos de Alumnos - Instituto INCUYO</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png"
        href="https://aula.incuyo.edu.ar/pluginfile.php/1/theme_academi/logo/1756927387/logo%203.png" />

    <!-- Stylesheet -->
    <link rel="stylesheet" href="/css/style.css" />

    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        /* Additional styles for projects page */
        .projects-hero {
            min-height: 50vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--gradient-dark);
            position: relative;
            padding: var(--space-24) 0 var(--space-16);
        }

        .projects-hero::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 30% 50%, rgba(195, 146, 21, 0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .projects-hero-content {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: var(--space-2);
            color: var(--primary-gold);
            font-weight: 600;
            margin-bottom: var(--space-6);
            transition: all var(--transition-base);
        }

        .back-link:hover {
            transform: translateX(-5px);
        }

        /* Year Tabs */
        .year-tabs {
            display: flex;
            justify-content: center;
            gap: var(--space-4);
            margin-bottom: var(--space-12);
            flex-wrap: wrap;
        }

        .year-tab {
            padding: var(--space-3) var(--space-8);
            border-radius: var(--radius-full);
            font-family: var(--font-heading);
            font-size: var(--text-base);
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition-base);
            border: 2px solid var(--gray-300);
            background: var(--white);
            color: var(--gray-600);
        }

        .year-tab:hover {
            border-color: var(--primary-gold);
            color: var(--primary-gold);
        }

        .year-tab.active {
            background: var(--gradient-accent);
            color: var(--white);
            border-color: var(--primary-gold);
            box-shadow: 0 4px 12px rgba(195, 146, 21, 0.3);
        }

        .year-section {
            display: none;
        }

        .year-section.active {
            display: block;
        }

        .no-projects {
            text-align: center;
            padding: var(--space-16) var(--space-8);
            color: var(--gray-400);
            font-size: var(--text-lg);
        }

        .no-projects i {
            font-size: 3rem;
            display: block;
            margin-bottom: var(--space-4);
        }

        /* Project Card Styles */
        .project-card {
            background: var(--white);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-lg);
            transition: all var(--transition-base);
            margin-bottom: var(--space-12);
        }

        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-xl);
        }

        .project-header {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: var(--space-6);
            padding: var(--space-8);
            align-items: center;
            background: linear-gradient(135deg, var(--gray-100) 0%, var(--off-white) 100%);
            border-bottom: 3px solid var(--primary-gold);
        }

        .student-photo {
            width: 80px;
            height: 80px;
            border-radius: var(--radius-full);
            object-fit: cover;
            border: 3px solid var(--primary-gold);
            box-shadow: var(--shadow-md);
        }

        .student-info h3 {
            color: var(--gray-900);
            font-size: var(--text-2xl);
            margin-bottom: var(--space-2);
        }

        .student-year {
            display: inline-block;
            background: var(--gradient-accent);
            color: var(--white);
            padding: var(--space-2) var(--space-4);
            border-radius: var(--radius-full);
            font-size: var(--text-sm);
            font-weight: 600;
        }

        .project-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-8);
            padding: var(--space-8);
        }

        .project-media {
            position: relative;
            border-radius: var(--radius-xl);
            overflow: hidden;
            aspect-ratio: 16/9;
            box-shadow: var(--shadow-md);
        }

        .project-media img,
        .project-media video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .project-details h4 {
            color: var(--gray-900);
            font-size: var(--text-xl);
            margin-bottom: var(--space-4);
            display: flex;
            align-items: center;
            gap: var(--space-3);
        }

        .project-description {
            color: var(--gray-600);
            line-height: 1.8;
            margin-bottom: var(--space-6);
        }

        .project-tech {
            display: flex;
            flex-wrap: wrap;
            gap: var(--space-2);
            margin-bottom: var(--space-6);
        }

        .tech-tag {
            background: var(--gray-100);
            color: var(--gray-800);
            padding: var(--space-2) var(--space-3);
            border-radius: var(--radius-md);
            font-size: var(--text-sm);
            font-weight: 500;
        }

        .project-actions {
            display: flex;
            gap: var(--space-4);
        }

        .btn-demo {
            flex: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: var(--space-2);
        }

        @media (max-width: 768px) {
            .project-content {
                grid-template-columns: 1fr;
            }

            .project-header {
                grid-template-columns: 1fr;
                text-align: center;
            }

            .student-photo {
                margin: 0 auto;
            }
        }
    </style>
</head>

<body>
    <!-- NAVIGATION -->
    <nav class="navbar scrolled" id="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <img src="/assets/img/logo.png" alt="Instituto Nuevo Cuyo" class="navbar-logo" />
            </a>

            <button class="navbar-toggle" id="navbarToggle" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <ul class="navbar-menu" id="navbarMenu">
                <li><a href="/#inicio">Inicio</a></li>
                <li><a href="/#inscripciones">Inscripciones</a></li>
                <li><a href="/proyectosalumnos">Proyectos</a></li>
                <li>
                    <a href="https://aula.incuyo.edu.ar/" target="_blank" class="campus-link">Campus Virtual</a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="projects-hero">
        <div class="container">
            <div class="projects-hero-content">
                <a href="/" class="back-link">
                    <i class="fas fa-arrow-left"></i> Volver al inicio
                </a>
                <h1 class="hero-title" style="color: var(--white)">
                    Proyectos de Alumnos
                </h1>
                <p class="hero-description" style="color: var(--gray-300)">
                    Descubrí los increíbles proyectos creados por nuestros estudiantes
                </p>
            </div>
        </div>
    </section>

    <!-- PROJECTS SECTION -->
    <section class="section" style="background: var(--gray-100)">
        <div class="container" style="max-width: 1200px">

            <!-- Year Tabs -->
            <div class="year-tabs">
                <button class="year-tab active" data-year="all">Todos</button>
                <button class="year-tab" data-year="1">1° Año</button>
                <button class="year-tab" data-year="2">2° Año</button>
                <button class="year-tab" data-year="3">3° Año</button>
            </div>

            <!-- All Projects per Year -->
            <% [1, 2, 3].forEach(function(year) { %>
                <% if (projects[year] && projects[year].length> 0) { %>
                    <% projects[year].forEach(function(project) { %>
                        <div class="project-card reveal" data-year="<%= year %>">
                            <div class="project-header">
                                <% if (project.student_photo_url) { %>
                                    <img src="<%= project.student_photo_url %>" alt="<%= project.student_name %>"
                                        class="student-photo" />
                                    <% } else { %>
                                        <div class="student-photo"
                                            style="display:flex;align-items:center;justify-content:center;background:var(--gradient-primary);color:white;font-size:2rem;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <% } %>
                                            <div class="student-info">
                                                <h3>
                                                    <%= project.student_name %>
                                                </h3>
                                                <span class="student-year">
                                                    <%= year %>° Año
                                                </span>
                                            </div>
                            </div>

                            <div class="project-content">
                                <div class="project-media">
                                    <% if (project.project_image_url) { %>
                                        <img src="<%= project.project_image_url %>"
                                            alt="<%= project.project_name %> Screenshot" loading="lazy" />
                                        <% } else { %>
                                            <div
                                                style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--gray-200);color:var(--gray-400);">
                                                <i class="fas fa-image" style="font-size:3rem;"></i>
                                            </div>
                                            <% } %>
                                </div>

                                <div class="project-details">
                                    <h4>
                                        <i class="<%= project.project_icon || 'fas fa-code' %>"
                                            style="color: var(--primary-gold)"></i>
                                        <%= project.project_name %>
                                    </h4>

                                    <p class="project-description">
                                        <%= project.project_description %>
                                    </p>

                                    <div class="project-tech">
                                        <% (project.tech_tags_arr || []).forEach(function(tag) { %>
                                            <span class="tech-tag">
                                                <%= tag %>
                                            </span>
                                            <% }); %>
                                    </div>

                                    <% if (project.project_demo_url) { %>
                                        <div class="project-actions">
                                            <a href="<%= project.project_demo_url %>" target="_blank"
                                                class="btn btn-primary btn-demo">
                                                <i class="fas fa-external-link-alt"></i> Ver Demo en Vivo
                                            </a>
                                        </div>
                                        <% } %>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                            <% } %>
                                <% }); %>

                                    <div class="no-projects" id="noProjects" style="display:none;">
                                        <i class="fas fa-folder-open"></i>
                                        Aún no hay proyectos en este año. ¡Pronto se sumarán!
                                    </div>

                                    <!-- CTA Section -->
                                    <div class="text-center" style="margin-top: var(--space-16)">
                                        <div class="card"
                                            style="background: var(--gradient-primary); color: white; max-width: 700px; margin: 0 auto;">
                                            <h3 class="card-title" style="color: white">
                                                ¿Querés crear proyectos como estos?
                                            </h3>
                                            <p class="card-text" style="color: rgba(255, 255, 255, 0.9)">
                                                Unite a nuestra Tecnicatura en Desarrollo de Software y aprendé a
                                                crear aplicaciones profesionales desde el primer año.
                                            </p>
                                            <a href="/#inscripciones" class="btn btn-secondary btn-lg"
                                                style="margin-top: var(--space-4)">
                                                <i class="fas fa-graduation-cap"></i> Inscribite Ahora
                                            </a>
                                        </div>
                                    </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Instituto INCUYO</h3>
                    <p>Instituto de Estudios Superiores Nuevo Cuyo PT-169</p>
                    <p>Formando profesionales en desarrollo de software con las últimas tecnologías e inteligencia
                        artificial.</p>
                </div>

                <div class="footer-section">
                    <h3>Enlaces Rápidos</h3>
                    <p><a href="/#inicio">Inicio</a></p>
                    <p><a href="/#programa">Programa</a></p>
                    <p><a href="/#curriculum">Curriculum</a></p>
                    <p><a href="/proyectosalumnos">Proyectos Alumnos</a></p>
                    <p><a href="https://aula.incuyo.edu.ar/" target="_blank">Campus Virtual</a></p>
                </div>

                <div class="footer-section">
                    <h3>Contacto</h3>
                    <div class="contact-item">
                        <i class="fas fa-phone contact-icon"></i>
                        <a href="tel:+5492616271658">(+054) 261 6271658</a>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-envelope contact-icon"></i>
                        <a href="mailto:incuyo@gmail.com">incuyo@gmail.com</a>
                    </div>
                    <div class="contact-item">
                        <i class="fas fa-map-marker-alt contact-icon"></i>
                        <span>La Rioja 614, Mendoza, Argentina</span>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <p>&copy; 2026 Instituto INCUYO - Todos los derechos reservados</p>
            </div>
        </div>
    </footer>

    <!-- WHATSAPP FLOATING BUTTON -->
    <div class="whatsapp-float">
        <a href="https://wa.me/5492616271658?text=Hola!%20Me%20gustaría%20recibir%20más%20información%20sobre%20la%20Tecnicatura%20en%20Desarrollo%20de%20Software"
            class="whatsapp-btn" target="_blank" aria-label="Contactar por WhatsApp">
            <i class="fab fa-whatsapp"></i>
        </a>
    </div>

    <!-- JavaScript -->
    <script src="/js/script.js"></script>
    <script>
        // Year tab filtering
        document.querySelectorAll('.year-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.year-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');

                const year = tab.dataset.year;
                const cards = document.querySelectorAll('.project-card');
                let visible = 0;

                cards.forEach(card => {
                    if (year === 'all' || card.dataset.year === year) {
                        card.style.display = '';
                        visible++;
                    } else {
                        card.style.display = 'none';
                    }
                });

                document.getElementById('noProjects').style.display = visible === 0 ? '' : 'none';
            });
        });
    </script>
</body>

</html>