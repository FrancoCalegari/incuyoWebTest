    <!-- JavaScript -->
    <script src="/js/script.js"></script>
    <script>
        // Lógica de interactividad y previsualización de video
        let idleTimer;
        const IDLE_TIMEOUT = 10000; // 10 segundos

        function playVideo(mediaContainer) {
            mediaContainer.classList.add('video-playing');
            const htmlVideo = mediaContainer.querySelector('video.html-video');
            const ytVideo = mediaContainer.querySelector('iframe.youtube-video');

            if (htmlVideo) {
                htmlVideo.play().catch(e => console.log('Autoplay prevent:', e));
            } else if (ytVideo) {
                ytVideo.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
            }
        }

        function pauseVideo(mediaContainer) {
            mediaContainer.classList.remove('video-playing');
            const htmlVideo = mediaContainer.querySelector('video.html-video');
            const ytVideo = mediaContainer.querySelector('iframe.youtube-video');

            if (htmlVideo) {
                htmlVideo.pause();
            } else if (ytVideo) {
                ytVideo.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
            }
        }

        // Configurar intersection observer para los videos automáticos
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.5 // 50% de visibilidad requerida
        };

        const autoPlayObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    playVideo(entry.target);
                } else {
                    pauseVideo(entry.target);
                }
            });
        }, observerOptions);

        function handleIdle() {
            // Empezar a observar videos visibles para reproducirlos
            document.querySelectorAll('.media-container.has-video').forEach(container => {
                // Solo si el contenedor está en un card que es visible (por el filtro de años)
                if (container.closest('.project-card').style.display !== 'none') {
                    autoPlayObserver.observe(container);
                }
            });
        }

        function resetIdleTimer() {
            clearTimeout(idleTimer);

            // Pausar observación automática
            document.querySelectorAll('.media-container.has-video').forEach(container => {
                autoPlayObserver.unobserve(container);
                // Si no se le está haciendo hover manualmente, pausar
                if (!container.matches(':hover') && !container.closest('.project-card').matches(':hover')) {
                    pauseVideo(container);
                }
            });

            // Reiniciar timer
            idleTimer = setTimeout(handleIdle, IDLE_TIMEOUT);
        }

        // Escuchar eventos de inactividad del usuario
        ['mousemove', 'mousedown', 'keypress', 'DOMMouseScroll', 'mousewheel', 'touchmove', 'MSPointerMove'].forEach(event => {
            document.addEventListener(event, resetIdleTimer, { passive: true });
        });

        // Configurar hover individual
        document.querySelectorAll('.project-card').forEach(card => {
            const mediaContainer = card.querySelector('.media-container.has-video');
            if (mediaContainer) {
                card.addEventListener('mouseenter', () => {
                    // Forzar reproducción al hacer hover, anulando el timer si era necesario
                    playVideo(mediaContainer);
                });
                card.addEventListener('mouseleave', () => {
                    // Si el timer de idle no se ha disparado (el usuario está activo), pausamos
                    // (el mouseleave de todas formas dispara resetIdleTimer porque es movimiento)
                    pauseVideo(mediaContainer);
                });
            }
        });

        // Iniciar timer
        resetIdleTimer();

        // Year tab filtering
        document.querySelectorAll('.year-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.year-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');

                const year = tab.dataset.year;
                const cards = document.querySelectorAll('.project-card');
                let visible = 0;

                cards.forEach(card => {
                    if (year === 'all' || card.dataset.year === year) {
                        card.style.display = '';
                        visible++;
                    } else {
                        card.style.display = 'none';
                    }
                });

                document.getElementById('noProjects').style.display = visible === 0 ? '' : 'none';
            });
        });
    </script>
</body>

