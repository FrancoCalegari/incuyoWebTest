<!doctype html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <meta name="description"
        content="Proyectos creados por alumnos del Instituto INCUYO - Tecnicatura en Desarrollo de Software. ¡Programando desde el primer año!" />
    <meta name="keywords"
        content="proyectos alumnos, desarrollo software, programación, Mendoza, INCUYO, tecnicatura" />
    <meta name="author" content="Instituto Nuevo Cuyo" />
    <title>Proyectos de Alumnos - Instituto INCUYO</title>

    <!-- Theme Color (barra de navegador en móvil) -->
    <meta name="theme-color" content="#10182c" />
    <meta name="msapplication-navbutton-color" content="#10182c" />
    <meta name="apple-mobile-web-app-status-bar-style" content="#10182c" />

    <!-- Open Graph / Facebook / WhatsApp / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://incuyo.edu.ar/proyectosalumnos" />
    <meta property="og:title" content="Proyectos de Alumnos - Instituto INCUYO" />
    <meta property="og:description"
        content="Conocé los proyectos reales creados por los alumnos del Instituto Nuevo Cuyo. Desde el primer año desarrollan sistemas personalizados con las últimas tecnologías." />
    <meta property="og:image" content="https://incuyo.edu.ar/img/webpreview.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Proyectos de Alumnos - Instituto Nuevo Cuyo" />
    <meta property="og:site_name" content="Instituto Nuevo Cuyo" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://incuyo.edu.ar/proyectosalumnos" />
    <meta name="twitter:title" content="Proyectos de Alumnos - Instituto INCUYO" />
    <meta name="twitter:description"
        content="Conocé los proyectos reales creados por los alumnos del Instituto Nuevo Cuyo. Desde el primer año desarrollan sistemas personalizados con las últimas tecnologías." />
    <meta name="twitter:image" content="https://incuyo.edu.ar/img/webpreview.png" />
    <meta name="twitter:image:alt" content="Proyectos de Alumnos - Instituto Nuevo Cuyo" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="/img/favicon.ico" />

    <!-- Stylesheet -->
    <link rel="stylesheet" href="/css/style.css" />

    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/proyectos.css" type="text/css" />
</head>

<body>
    <!-- NAVIGATION -->
    <nav class="navbar" id="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <img src="/assets/img/logo.png" alt="Instituto Nuevo Cuyo" class="navbar-logo" />
            </a>

            <button class="navbar-toggle" id="navbarToggle" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <ul class="navbar-menu" id="navbarMenu">
                <li><a href="/" class="btn btn-secondary-no-bg"
                        style="padding: 0.5rem 1rem; border-radius: 4px; font-weight: 600;"><i class="fas fa-arrow-left"
                            style="margin-right: 5px;"></i> Volver al Inicio</a></li>
            </ul>

        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="projects-hero">
        <div class="container">
            <div class="projects-hero-content">
                <h1 class="hero-title" style="color: var(--white)">
                    Proyectos de Alumnos
                </h1>
                <p class="hero-description" style="color: var(--gray-300)">
                    Descubrí los increíbles proyectos creados por nuestros estudiantes
                </p>
            </div>
        </div>
    </section>

    <!-- PROJECTS SECTION -->
    <section class="section" style="background: var(--gray-100)">
        <div class="container" style="max-width: 1200px">

            <!-- Year Tabs
            <div class="year-tabs">
                <button class="year-tab active" data-year="all">Todos</button>
                <button class="year-tab" data-year="1">1° Año</button>
                <button class="year-tab" data-year="2">2° Año</button>
                <button class="year-tab" data-year="3">3° Año</button>
            </div> -->

            <!-- All Projects per Year -->
            <% [1, 2, 3].forEach(function(year) { %>
                <% if (projects[year] && projects[year].length> 0) { %>
                    <% projects[year].forEach(function(project) { %>
                        <div class="project-card reveal" data-year="<%= year %>">
                            <div class="project-header">
                                <% let photoUrl=project.student_photo_url; if (photoUrl &&
                                    photoUrl.includes('/api/v1/storage/files/')) { const
                                    fileId=photoUrl.split('/api/v1/storage/files/')[1].split('?')[0];
                                    photoUrl=`/api/storage/files/${fileId}`; } if (photoUrl) { %>
                                    <img src="<%= photoUrl %>" alt="<%= project.student_name %>"
                                        class="student-photo" />
                                    <% } else { %>
                                        <div class="student-photo"
                                            style="display:flex;align-items:center;justify-content:center;background:var(--gradient-primary);color:white;font-size:2rem;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <% } %>
                                            <div class="student-info">
                                                <h3>
                                                    <%= project.student_name %>
                                                </h3>
                                                <span class="student-year">
                                                    <%= year %>° Año
                                                </span>
                                            </div>
                            </div>

                            <div class="project-content">
                                <div class="project-media">
                                    <% let projImageUrl=project.project_image_url; if (projImageUrl &&
                                        projImageUrl.includes('/api/v1/storage/files/')) { const
                                        fileId=projImageUrl.split('/api/v1/storage/files/')[1].split('?')[0];
                                        projImageUrl=`/api/storage/files/${fileId}`; } let
                                        videoUrl=project.project_demo_url; let isYoutube=videoUrl &&
                                        (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')); let
                                        isCloudVideo=videoUrl && (videoUrl.includes('/api/v1/storage/files/') ||
                                        videoUrl.toLowerCase().endsWith('.mp4')); let isVideo=isYoutube || isCloudVideo;
                                        %>
                                        <div class="media-container <%= isVideo ? 'has-video' : '' %>">
                                            <% if (projImageUrl) { %>
                                                <img src="<%= projImageUrl %>"
                                                    alt="<%= project.project_name %> Screenshot" loading="lazy"
                                                    class="project-image" />
                                                <% } else { %>
                                                    <div class="project-image"
                                                        style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--gray-200);color:var(--gray-400);">
                                                        <i class="fas fa-image" style="font-size:3rem;"></i>
                                                    </div>
                                                    <% } %>

                                                        <% if (isVideo) { %>
                                                            <% if (isYoutube) { let ytId='' ; if
                                                                (videoUrl.includes('youtube.com/watch?v=')) {
                                                    ytId = videoUrl.split(' v=')[1].split(' &')[0]; } else if
                                                                (videoUrl.includes('youtu.be/')) {
                                                                ytId=videoUrl.split('youtu.be/')[1].split('?')[0]; } if
                                                                (ytId) { %>
                                                                <iframe class="project-video youtube-video"
                                                                    src="https://www.youtube.com/embed/<%= ytId %>?enablejsapi=1&autoplay=0&mute=1&controls=0&loop=1&playlist=<%= ytId %>"
                                                                    frameborder="0" allow="autoplay; encrypted-media"
                                                                    allowfullscreen></iframe>
                                                                <% } } else { if
                                                                    (videoUrl.includes('/api/v1/storage/files/')) {
                                                                    const
                                                                    fileId=videoUrl.split('/api/v1/storage/files/')[1].split('?')[0];
                                                                    videoUrl=`/api/storage/files/${fileId}`; } %>
                                                                    <video class="project-video html-video"
                                                                        src="<%= videoUrl %>" muted loop playsinline
                                                                        preload="none"></video>
                                                                    <% } %>
                                                                        <% } %>
                                        </div>
                                </div>

                                <div class="project-details">
                                    <h4>
                                        <i class="<%= project.project_icon || 'fas fa-code' %>"
                                            style="color: var(--primary-gold)"></i>
                                        <%= project.project_name %>
                                    </h4>

                                    <p class="project-description">
                                        <%= project.project_description %>
                                    </p>

                                    <div class="project-tech">
                                        <% (project.tech_tags_arr || []).forEach(function(tag) { %>
                                            <span class="tech-tag">
                                                <%= tag %>
                                            </span>
                                            <% }); %>
                                    </div>

                                    <% if (project.project_demo_url && !isVideo) { %>
                                        <div class="project-actions">
                                            <a href="<%= project.project_demo_url %>" target="_blank"
                                                class="btn btn-primary btn-demo">
                                                <i class="fas fa-external-link-alt"></i> Ver Demo en Vivo
                                            </a>
                                        </div>
                                        <% } %>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                            <% } %>
                                <% }); %>

                                    <div class="no-projects" id="noProjects" style="display:none;">
                                        <i class="fas fa-folder-open"></i>
                                        Aún no hay proyectos en este año. ¡Pronto se sumarán!
                                    </div>

                                    <!-- CTA Section -->
                                    <div class="text-center" style="margin-top: var(--space-16)">
                                        <div class="card"
                                            style="background: var(--gradient-primary); color: white; max-width: 700px; margin: 0 auto;">
                                            <h3 class="card-title" style="color: white">
                                                ¿Querés crear proyectos como estos?
                                            </h3>
                                            <p class="card-text" style="color: rgba(255, 255, 255, 0.9)">
                                                Unite a nuestra Tecnicatura en Desarrollo de Software y aprendé a
                                                crear aplicaciones profesionales desde el primer año.
                                            </p>
                                            <!-- <a href="/#inscripciones" class="btn btn-secondary btn-lg"
                                                style="margin-top: var(--space-4)">
                                                <i class="fas fa-graduation-cap"></i> Inscribite Ahora
                                            </a> -->
                                        </div>
                                    </div>
        </div>
    </section>

    <!-- TESTIMONIOS SECTION -->
    <% if (testimonios && testimonios.length> 0) { %>
        <section class="section" style="background: var(--white)">
            <div class="container" style="max-width: 1200px">
                <h2 class="section-title text-center" style="margin-bottom: var(--space-12)">Testimonios de nuestros
                    Egresados</h2>
                <div class="projects-grid"
                    style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-8);">
                    <% testimonios.forEach(function(t) { %>
                        <div class="project-card reveal">
                            <div class="project-header" style="background: var(--gray-100);">
                                <div class="student-photo"
                                    style="display:flex;align-items:center;justify-content:center;background:var(--gradient-primary);color:white;font-size:2rem;">
                                    <i class="fas fa-user-graduate"></i>
                                </div>
                                <div class="student-info">
                                    <h3>
                                        <%= t.student_name %>
                                    </h3>
                                    <span class="student-year">
                                        <%= t.student_role %>
                                    </span>
                                </div>
                            </div>

                            <% if (t.video_url) { %>
                                <div class="project-media">
                                    <% let videoUrl=t.video_url; let isYoutube=videoUrl.includes('youtube.com') ||
                                        videoUrl.includes('youtu.be'); %>
                                        <div class="media-container has-video">
                                            <% 
                                                if (isYoutube) { 
                                                    let ytId = '';
                                                    if (videoUrl.includes('youtube.com/watch?v=')) { 
                                                        ytId = videoUrl.split('v=')[1].split('&')[0]; 
                                                    } else if (videoUrl.includes('youtu.be/')) {
                                                        ytId = videoUrl.split('youtu.be/')[1].split('?')[0]; 
                                                    } 
                                                    if (ytId) { 
                                            %>
                                                <iframe class="project-video youtube-video"
                                                    src="https://www.youtube.com/embed/<%= ytId %>?enablejsapi=1&autoplay=0&controls=1&loop=0"
                                                    frameborder="0" allow="autoplay; encrypted-media"
                                                    allowfullscreen></iframe>
                                                <% } } else { if (videoUrl.includes('/api/v1/storage/files/')) { const
                                                    fileId=videoUrl.split('/api/v1/storage/files/')[1].split('?')[0];
                                                    videoUrl=`/api/storage/files/${fileId}`; } %>
                                                    <video class="project-video html-video" controls preload="metadata"
                                                        playsinline>
                                                        <source src="<%= videoUrl %>" type="video/mp4">
                                                        Tu navegador no soporta la reproducción de video.
                                                    </video>
                                                    <% } %>
                                        </div>
                                </div>
                                <% } %>
                        </div>
                        <% }); %>
                </div>
            </div>
        </section>
        <% } %>

            <!-- FOOTER -->
            <footer class="footer">
                <div class="container">
                    <div class="footer-content">
                        <div class="footer-section">
                            <h3>Instituto INCUYO</h3>
                            <p>Instituto de Estudios Superiores Nuevo Cuyo PT-169</p>
                            <p>Formando profesionales en desarrollo de software con las últimas tecnologías e
                                inteligencia
                                artificial.</p>
                        </div>

                        <div class="footer-section">
                            <h3>Enlaces Rápidos</h3>
                            <p><a href="/#inicio">Inicio</a></p>
                            <p><a href="/#programa">Programa</a></p>
                            <p><a href="/#curriculum">Curriculum</a></p>
                            <p><a href="/proyectosalumnos">Proyectos Alumnos</a></p>
                            <p><a href="https://aula.incuyo.edu.ar/" target="_blank">Campus Virtual</a></p>
                        </div>

                        <div class="footer-section">
                            <h3>Contacto</h3>
                            <div class="contact-item">
                                <i class="fas fa-phone contact-icon"></i>
                                <a href="tel:+5492616271658">(+054) 261 6271658</a>
                            </div>
                            <div class="contact-item">
                                <i class="fas fa-envelope contact-icon"></i>
                                <a href="mailto:incuyo@gmail.com">incuyo@gmail.com</a>
                            </div>
                            <div class="contact-item">
                                <i class="fas fa-map-marker-alt contact-icon"></i>
                                <span>La Rioja 614, Mendoza, Argentina</span>
                            </div>
                        </div>
                    </div>

                    <div class="footer-bottom">
                        <p>&copy; 2026 Instituto INCUYO - Todos los derechos reservados</p>
                    </div>
                </div>
            </footer>

            <!-- WHATSAPP FLOATING BUTTON -->
            <div class="whatsapp-float">
                <a href="https://wa.me/5492616271658?text=Hola!%20Me%20gustaría%20recibir%20más%20información%20sobre%20la%20Tecnicatura%20en%20Desarrollo%20de%20Software"
                    class="whatsapp-btn" target="_blank" aria-label="Contactar por WhatsApp">
                    <i class="fab fa-whatsapp"></i>
                </a>
            </div>

            <!-- JavaScript -->
            <script src="/js/script.js"></script>
            <script>

                // Year tab filtering
                document.querySelectorAll('.year-tab').forEach(tab => {
                    tab.addEventListener('click', () => {
                        document.querySelectorAll('.year-tab').forEach(t => t.classList.remove('active'));
                        tab.classList.add('active');

                        const year = tab.dataset.year;
                        const cards = document.querySelectorAll('.project-card');
                        let visible = 0;

                        cards.forEach(card => {
                            if (year === 'all' || card.dataset.year === year) {
                                card.style.display = '';
                                visible++;
                            } else {
                                card.style.display = 'none';
                            }
                        });

                        document.getElementById('noProjects').style.display = visible === 0 ? '' : 'none';
                    });
                });
            </script>
</body>

</html>